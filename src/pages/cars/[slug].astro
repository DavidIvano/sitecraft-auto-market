---
import StatusBadge from "../../components/StatusBadge.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SITE_URL } from "../../lib/config";
import { getApprovedCars } from "../../lib/xano";
import type { CarListing } from "../../lib/types";

export async function getStaticPaths() {
  try {
    const cars = await getApprovedCars();

    return cars.map((car) => ({
      params: { slug: car.slug },
      props: { car },
    }));
  } catch (error) {
    console.warn(error);
    return [];
  }
}

const { car } = Astro.props as { car: CarListing };
const siteUrl = SITE_URL || "https://sitecraft-auto-market.pages.dev";
const carUrl = new URL(`/cars/${car.slug}`, siteUrl).toString();
const formatter = new Intl.NumberFormat("ru-RU", {
  style: "currency",
  currency: car.currency,
  maximumFractionDigits: 0,
});

const toDate = (value?: string | number) => {
  if (!value) {
    return null;
  }

  const date =
    typeof value === "number" || /^\d+$/.test(String(value))
      ? new Date(Number(value))
      : new Date(value);

  return Number.isNaN(date.getTime()) ? null : date;
};

const createdAt = toDate(car.created_at);
const createdAtLabel = createdAt
  ? new Intl.DateTimeFormat("ru-RU", {
      dateStyle: "medium",
      timeStyle: "short",
    }).format(createdAt)
  : "дата уточняется";

const galleryImages = [
  car.main_image_url,
  ...(car.images ?? []).map((image) => image.image_url),
]
  .filter(Boolean)
  .filter((value, index, array) => array.indexOf(value) === index)
  .slice(0, 5) as string[];
const galleryImage = galleryImages[0] ?? "";
const cleanPhone = car.seller_phone?.replace(/[^\d+]/g, "") ?? "";
const contactHref = cleanPhone
  ? `tel:${cleanPhone}`
  : car.seller_email
    ? `mailto:${car.seller_email}`
    : "";
const contactLabel = car.seller_phone
  ? `Связаться: ${car.seller_phone}`
  : car.seller_email
    ? `Написать: ${car.seller_email}`
    : "Контакты не указаны";
const cleanSeoText = (value: string) =>
  value
    .split(/\r?\n/)
    .filter((line) => !/^(телефон|email|e-mail|продавец|vin)\s*:/i.test(line.trim()))
    .join(" ")
    .replace(/\s+/g, " ")
    .trim();
const seoDescriptionText = cleanSeoText(car.description);
const description = `${car.title}: ${formatter.format(car.price)}, ${car.year}, ${car.mileage.toLocaleString("ru-RU")} км, ${car.city}.${seoDescriptionText ? ` ${seoDescriptionText}` : ""}`.slice(0, 260);

const carSchema = {
  "@context": "https://schema.org",
  "@type": "Vehicle",
  name: car.title,
  url: carUrl,
  image: galleryImages,
  brand: {
    "@type": "Brand",
    name: car.brand,
  },
  model: car.model,
  vehicleModelDate: String(car.year),
  mileageFromOdometer: {
    "@type": "QuantitativeValue",
    value: car.mileage,
    unitCode: "KMT",
  },
  fuelType: car.fuel_type,
  vehicleTransmission: car.transmission,
  description,
  offers: {
    "@type": "Offer",
    price: car.price,
    priceCurrency: car.currency,
    availability: "https://schema.org/InStock",
    url: carUrl,
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Главная",
      item: siteUrl,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Автомобили",
      item: new URL("/cars", siteUrl).toString(),
    },
    {
      "@type": "ListItem",
      position: 3,
      name: car.title,
      item: carUrl,
    },
  ],
};
---

<BaseLayout
  title={car.title}
  description={description}
  canonicalPath={`/cars/${car.slug}`}
  image={galleryImage || "/sitecraft-logo.png"}
  jsonLd={[carSchema, breadcrumbSchema]}
>
  <section class="section car-detail-section">
    <div class="container detail-container">
      <article class="detail-grid car-detail-grid">
        <div class="gallery car-slider" data-gallery>
          <div class="gallery-stage">
            {
              galleryImages.length > 1 && (
                <button class="gallery-nav gallery-prev" type="button" aria-label="Предыдущее фото">‹</button>
              )
            }
            <button class="gallery-main-button" type="button" data-static-lightbox-open aria-label="Открыть фото на весь экран">
              {
                galleryImage ? (
                  <img src={galleryImage} alt={car.title} />
                ) : (
                  <div class="gallery-empty">Фото пока не добавлено</div>
                )
              }
            </button>
            {
              galleryImages.length > 1 && (
                <button class="gallery-nav gallery-next" type="button" aria-label="Следующее фото">›</button>
              )
            }
            <span class="gallery-count">{galleryImages.length > 0 ? `1 / ${galleryImages.length}` : "0 / 0"}</span>
          </div>
          <div class="gallery-strip">
            {
              galleryImages.length > 0 ? (
                galleryImages.map((imageUrl, index) => (
                  <button
                    class={`gallery-thumb${index === 0 ? " is-active" : ""}`}
                    type="button"
                    data-slide-index={index}
                    style={`background-image:url('${imageUrl}');`}
                    aria-label={`Фото ${index + 1}`}
                  />
                ))
              ) : (
                <>
                  <span />
                  <span />
                  <span />
                </>
              )
            }
          </div>
        </div>
        <div class="detail-panel compact-detail-panel">
          <StatusBadge status={car.status} />
          <h1>{car.title}</h1>
          <p class="detail-price">{formatter.format(car.price)}</p>
          <dl class="spec-grid detail-spec-grid">
            <div>
              <dt>Год</dt>
              <dd>{car.year}</dd>
            </div>
            <div>
              <dt>Пробег</dt>
              <dd>{car.mileage.toLocaleString("ru-RU")} км</dd>
            </div>
            <div>
              <dt>Топливо</dt>
              <dd>{car.fuel_type}</dd>
            </div>
            <div>
              <dt>Коробка</dt>
              <dd>{car.transmission}</dd>
            </div>
            <div>
              <dt>Город</dt>
              <dd>{car.city}, {car.country}</dd>
            </div>
            <div>
              <dt>Добавлено</dt>
              <dd>{createdAtLabel}</dd>
            </div>
          </dl>
          <p class="detail-description">{car.description}</p>
          {
            contactHref ? (
              <a class="button button-dark full-width" href={contactHref}>{contactLabel}</a>
            ) : (
              <button class="button button-dark full-width" type="button" disabled>{contactLabel}</button>
            )
          }
        </div>
        <div class="lightbox" id="static-car-lightbox" hidden>
          <button class="lightbox-close" type="button" aria-label="Закрыть фото">×</button>
          {
            galleryImages.length > 1 && (
              <>
                <button class="lightbox-nav lightbox-prev" type="button" aria-label="Предыдущее фото">‹</button>
                <button class="lightbox-nav lightbox-next" type="button" aria-label="Следующее фото">›</button>
                <span class="lightbox-count">{`1 / ${galleryImages.length}`}</span>
              </>
            )
          }
          {galleryImage && <img src={galleryImage} alt={car.title} />}
        </div>
      </article>
    </div>
  </section>
  <script>
    const galleryImages = Array.from(document.querySelectorAll(".gallery-thumb"))
      .map((thumb) => thumb instanceof HTMLElement ? thumb.style.backgroundImage.slice(5, -2) : "")
      .filter(Boolean);
    const openButton = document.querySelector("[data-static-lightbox-open]");
    const mainImage = document.querySelector(".gallery-main-button img");
    const galleryCount = document.querySelector(".gallery-count");
    const prevButton = document.querySelector(".gallery-prev");
    const nextButton = document.querySelector(".gallery-next");
    const lightbox = document.querySelector("#static-car-lightbox");
    const lightboxImage = lightbox?.querySelector("img");
    const closeButton = lightbox?.querySelector(".lightbox-close");
    const lightboxPrevButton = lightbox?.querySelector(".lightbox-prev");
    const lightboxNextButton = lightbox?.querySelector(".lightbox-next");
    const lightboxCount = lightbox?.querySelector(".lightbox-count");
    let activeSlideIndex = 0;

    const updateLightbox = () => {
      if (lightboxImage instanceof HTMLImageElement) {
        lightboxImage.src = galleryImages[activeSlideIndex] || lightboxImage.src;
      }

      if (lightboxCount instanceof HTMLElement) {
        lightboxCount.textContent = `${activeSlideIndex + 1} / ${galleryImages.length}`;
      }
    };

    const updateSlide = (nextIndex: number) => {
      if (galleryImages.length === 0) {
        return;
      }

      activeSlideIndex = (nextIndex + galleryImages.length) % galleryImages.length;
      const imageUrl = galleryImages[activeSlideIndex];

      if (mainImage instanceof HTMLImageElement) {
        mainImage.src = imageUrl;
      }

      if (galleryCount instanceof HTMLElement) {
        galleryCount.textContent = `${activeSlideIndex + 1} / ${galleryImages.length}`;
      }

      updateLightbox();

      document.querySelectorAll(".gallery-thumb").forEach((thumb) => {
        if (thumb instanceof HTMLElement) {
          thumb.classList.toggle("is-active", thumb.dataset.slideIndex === String(activeSlideIndex));
        }
      });
    };

    prevButton?.addEventListener("click", () => updateSlide(activeSlideIndex - 1));
    nextButton?.addEventListener("click", () => updateSlide(activeSlideIndex + 1));
    lightboxPrevButton?.addEventListener("click", () => updateSlide(activeSlideIndex - 1));
    lightboxNextButton?.addEventListener("click", () => updateSlide(activeSlideIndex + 1));

    document.querySelectorAll(".gallery-thumb").forEach((button) => {
      button.addEventListener("click", () => {
        if (button instanceof HTMLElement) {
          updateSlide(Number(button.dataset.slideIndex || 0));
        }
      });
    });

    openButton?.addEventListener("click", () => {
      if (lightbox instanceof HTMLElement && lightboxImage instanceof HTMLImageElement) {
        updateLightbox();
        lightbox.hidden = false;
      }
    });

    closeButton?.addEventListener("click", () => {
      if (lightbox instanceof HTMLElement) {
        lightbox.hidden = true;
      }
    });

    lightbox?.addEventListener("click", (event) => {
      if (event.target === lightbox && lightbox instanceof HTMLElement) {
        lightbox.hidden = true;
      }
    });

    document.addEventListener("keydown", (event) => {
      if (!(lightbox instanceof HTMLElement) || lightbox.hidden) {
        return;
      }

      if (event.key === "Escape") {
        lightbox.hidden = true;
      }

      if (event.key === "ArrowLeft") {
        updateSlide(activeSlideIndex - 1);
      }

      if (event.key === "ArrowRight") {
        updateSlide(activeSlideIndex + 1);
      }
    });
  </script>
</BaseLayout>
