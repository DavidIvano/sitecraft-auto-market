---
import StatusBadge from "../../components/StatusBadge.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { mockCars } from "../../lib/mockCars";
import { getCarBySlug } from "../../lib/xano";

export function getStaticPaths() {
  return mockCars.map((car) => ({
    params: { slug: car.slug },
  }));
}

const { slug } = Astro.params;
let car = mockCars.find((item) => item.slug === slug) ?? null;

try {
  if (slug) {
    car = (await getCarBySlug(slug)) ?? car;
  }
} catch (error) {
  console.warn(error);
}

const formatter =
  car &&
  new Intl.NumberFormat("ru-RU", {
    style: "currency",
    currency: car.currency,
    maximumFractionDigits: 0,
  });

const cleanPhone = car?.seller_phone?.replace(/[^\d+]/g, "") ?? "";
const contactHref = cleanPhone
  ? `tel:${cleanPhone}`
  : car?.seller_email
    ? `mailto:${car.seller_email}`
    : "";
const contactLabel = car?.seller_phone
  ? `Связаться: ${car.seller_phone}`
  : car?.seller_email
    ? `Написать: ${car.seller_email}`
    : "Контакты не указаны";
---

<BaseLayout title={car?.title ?? "Автомобиль не найден"}>
  <section class="section">
    <div class="container">
      {
        car ? (
          <article class="detail-grid">
            <div class="gallery">
              <button class="gallery-main-button" type="button" data-static-lightbox-open aria-label="Открыть фото на весь экран">
                <img src={car.main_image_url} alt={car.title} />
              </button>
              <div class="gallery-strip">
                <span />
                <span />
                <span />
              </div>
            </div>
            <div class="detail-panel">
              <StatusBadge status="approved" />
              <h1>{car.title}</h1>
              <p class="detail-price">{formatter?.format(car.price)}</p>
              <dl class="spec-grid">
                <div>
                  <dt>Год</dt>
                  <dd>{car.year}</dd>
                </div>
                <div>
                  <dt>Пробег</dt>
                  <dd>{car.mileage.toLocaleString("ru-RU")} км</dd>
                </div>
                <div>
                  <dt>Топливо</dt>
                  <dd>{car.fuel_type}</dd>
                </div>
                <div>
                  <dt>Коробка</dt>
                  <dd>{car.transmission}</dd>
                </div>
                <div>
                  <dt>Город</dt>
                  <dd>
                    {car.city}, {car.country}
                  </dd>
                </div>
              </dl>
              <p>{car.description}</p>
              {
                contactHref ? (
                  <a class="button button-dark full-width" href={contactHref}>{contactLabel}</a>
                ) : (
                  <button class="button button-dark full-width" type="button" disabled>{contactLabel}</button>
                )
              }
            </div>
            <div class="lightbox" id="static-car-lightbox" hidden>
              <button class="lightbox-close" type="button" aria-label="Закрыть фото">×</button>
              <img src={car.main_image_url} alt={car.title} />
            </div>
          </article>
        ) : (
          <div class="empty-state">
            <h1>Автомобиль не найден</h1>
            <p>Объявление могло быть снято с публикации или ещё не прошло модерацию.</p>
            <a class="button button-dark" href="/cars">Вернуться в каталог</a>
          </div>
        )
      }
    </div>
  </section>
  <script>
    const openButton = document.querySelector("[data-static-lightbox-open]");
    const lightbox = document.querySelector("#static-car-lightbox");
    const closeButton = lightbox?.querySelector(".lightbox-close");

    openButton?.addEventListener("click", () => {
      if (lightbox instanceof HTMLElement) {
        lightbox.hidden = false;
      }
    });

    closeButton?.addEventListener("click", () => {
      if (lightbox instanceof HTMLElement) {
        lightbox.hidden = true;
      }
    });

    lightbox?.addEventListener("click", (event) => {
      if (event.target === lightbox && lightbox instanceof HTMLElement) {
        lightbox.hidden = true;
      }
    });
  </script>
</BaseLayout>
