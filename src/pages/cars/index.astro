---
import CarCard from "../../components/CarCard.astro";
import SearchBar from "../../components/SearchBar.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getApprovedCars } from "../../lib/xano";
import { SITE_URL } from "../../lib/config";
import type { CarListing } from "../../lib/types";

let cars: CarListing[] = [];
const xanoApiUrl = import.meta.env.PUBLIC_XANO_API_URL;
const placeholderApiUrl = "https://your-xano-api-url.com/api:YOUR_GROUP";
const siteUrl = SITE_URL || "https://sitecraft-auto-market.pages.dev";

const toTimestamp = (value?: string | number) => {
  if (!value) {
    return 0;
  }

  const date =
    typeof value === "number" || /^\d+$/.test(String(value))
      ? new Date(Number(value))
      : new Date(value);

  return Number.isNaN(date.getTime()) ? 0 : date.getTime();
};

try {
  const xanoCars = await getApprovedCars();
  cars = [...xanoCars].sort((left, right) => toTimestamp(right.created_at) - toTimestamp(left.created_at));
} catch (error) {
  console.warn(error);
}

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Автомобили",
  description: "Каталог опубликованных автомобилей SiteCraft Auto Market",
  mainEntity: {
    "@type": "ItemList",
    itemListElement: cars.map((car, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: new URL(`/cars/${car.slug}`, siteUrl).toString(),
      name: car.title,
    })),
  },
};
---

<BaseLayout
  title="Автомобили"
  description="Каталог проверенных автомобилей SiteCraft Auto Market"
  canonicalPath="/cars"
  jsonLd={collectionSchema}
>
  <section class="section page-hero">
    <div class="container">
      <p class="eyebrow">Каталог</p>
      <h1>Автомобили</h1>
      <p class="lead">Свежие опубликованные объявления из Xano без повторов и demo-карточек.</p>
      <SearchBar />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div
        class="cards-grid"
        id="live-cars-grid"
        data-api-url={xanoApiUrl}
        data-placeholder-url={placeholderApiUrl}
      >
        {cars.map((car) => <CarCard car={car} />)}
      </div>
      <p class="form-message" id="live-cars-message">
        {cars.length > 0 ? "Показаны актуальные объявления из Xano." : "Загружаю каталог из Xano..."}
      </p>
    </div>
  </section>

  <script>
    const grid = document.querySelector("#live-cars-grid");
    const message = document.querySelector("#live-cars-message");

    const formatPrice = (price: unknown, currency: unknown) =>
      new Intl.NumberFormat("ru-RU", {
        style: "currency",
        currency: String(currency || "EUR"),
        maximumFractionDigits: 0,
      }).format(Number(price || 0));

    const escapeHtml = (value: unknown) =>
      String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");

    const toDate = (value: unknown) => {
      if (!value) {
        return null;
      }

      const stringValue = String(value);
      const date = typeof value === "number" || /^\d+$/.test(stringValue)
        ? new Date(Number(value))
        : new Date(stringValue);

      return Number.isNaN(date.getTime()) ? null : date;
    };

    const formatDate = (value: unknown) => {
      const date = toDate(value);

      if (!date) {
        return "дата уточняется";
      }

      return new Intl.DateTimeFormat("ru-RU", {
        dateStyle: "medium",
        timeStyle: "short",
      }).format(date);
    };

    const newestFirst = (cars: Array<Record<string, unknown>>) =>
      [...cars].sort((left, right) => {
        const leftTime = toDate(left.created_at)?.getTime() ?? 0;
        const rightTime = toDate(right.created_at)?.getTime() ?? 0;
        return rightTime - leftTime;
      });

    const renderCarImage = (car: Record<string, unknown>) => {
      if (car.main_image_url) {
        return `<img src="${escapeHtml(car.main_image_url)}" alt="${escapeHtml(car.title)}" class="car-image" loading="lazy" />`;
      }

      return `<div class="car-image car-image-empty">Фото в Xano не добавлено</div>`;
    };

    if (grid instanceof HTMLElement && message instanceof HTMLElement) {
      const apiUrl = grid.dataset.apiUrl;
      const placeholderUrl = grid.dataset.placeholderUrl;

      if (apiUrl && apiUrl !== placeholderUrl) {
        fetch(`${apiUrl}/cars`)
          .then((response) => {
            if (!response.ok) {
              throw new Error("Failed to load cars");
            }

            return response.json();
          })
          .then((cars) => {
            if (!Array.isArray(cars) || cars.length === 0) {
              grid.innerHTML = "";
              message.textContent = "В Xano пока нет опубликованных объявлений.";
              return;
            }

            grid.innerHTML = newestFirst(cars)
              .map((car) => {
                const slug = String(car.slug || "");

                return `
                  <article class="car-card">
                    <a class="car-image-link" href="/cars/${encodeURIComponent(slug)}" aria-label="Смотреть ${escapeHtml(car.title)}">
                      ${renderCarImage(car)}
                    </a>
                    <div class="car-card-body">
                      <div class="car-card-top">
                        <h3>${escapeHtml(car.title)}</h3>
                        <span class="status-badge status-approved">Проверено модератором</span>
                      </div>
                      <p class="car-price">${formatPrice(car.price, car.currency)}</p>
                      <p class="car-date">Добавлено: ${formatDate(car.created_at)}</p>
                      <dl class="car-meta">
                        <div><dt>Год</dt><dd>${escapeHtml(car.year)}</dd></div>
                        <div><dt>Пробег</dt><dd>${Number(car.mileage || 0).toLocaleString("ru-RU")} км</dd></div>
                        <div><dt>Город</dt><dd>${escapeHtml(car.city)}</dd></div>
                      </dl>
                      <a class="button button-light full-width" href="/cars/${encodeURIComponent(slug)}">Смотреть</a>
                    </div>
                  </article>
                `;
              })
              .join("");

            message.textContent = "Показаны актуальные объявления из Xano.";
          })
          .catch((error) => {
            console.error(error);
            message.textContent = grid.children.length > 0
              ? "Показаны объявления, загруженные во время последней публикации сайта."
              : "Не удалось загрузить Xano-каталог.";
          });
      }
    }
  </script>
</BaseLayout>
