---
import BaseLayout from "../../layouts/BaseLayout.astro";

const xanoApiUrl = import.meta.env.PUBLIC_XANO_API_URL;
const placeholderApiUrl = "https://your-xano-api-url.com/api:YOUR_GROUP";
---

<BaseLayout title="Автомобиль" breadcrumbs={[]}>
  <section class="section car-detail-section">
    <div class="container detail-container">
      <div
        id="live-car-detail"
        data-api-url={xanoApiUrl}
        data-placeholder-url={placeholderApiUrl}
      >
        <div class="empty-state">
          <h1>Загрузка автомобиля</h1>
          <p>Получаю данные объявления из Xano.</p>
        </div>
      </div>
    </div>
  </section>

  <script>
    const root = document.querySelector("#live-car-detail");

    const escapeHtml = (value: unknown) =>
      String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");

    const formatPrice = (price: unknown, currency: string) =>
      new Intl.NumberFormat("ru-RU", {
        style: "currency",
        currency: currency || "EUR",
        maximumFractionDigits: 0,
      }).format(Number(price || 0));

    const toDate = (value: unknown) => {
      if (!value) {
        return null;
      }

      const stringValue = String(value);
      const date = typeof value === "number" || /^\d+$/.test(stringValue)
        ? new Date(Number(value))
        : new Date(stringValue);

      return Number.isNaN(date.getTime()) ? null : date;
    };

    const formatDate = (value: unknown) => {
      const date = toDate(value);

      if (!date) {
        return "дата уточняется";
      }

      return new Intl.DateTimeFormat("ru-RU", {
        dateStyle: "medium",
        timeStyle: "short",
      }).format(date);
    };

    const normalizePhoneHref = (phone: unknown) => {
      const cleanPhone = String(phone ?? "").replace(/[^\d+]/g, "");
      return cleanPhone ? `tel:${cleanPhone}` : "";
    };

    const renderEmpty = (title: string, text: string) => {
      if (!(root instanceof HTMLElement)) {
        return;
      }

      root.innerHTML = `
        <div class="empty-state">
          <h1>${escapeHtml(title)}</h1>
          <p>${escapeHtml(text)}</p>
          <a class="button button-dark" href="/cars">Вернуться в каталог</a>
        </div>
      `;
    };

    if (root instanceof HTMLElement) {
      const apiUrl = root.dataset.apiUrl;
      const placeholderUrl = root.dataset.placeholderUrl;
      const slugFromQuery = new URLSearchParams(window.location.search).get("slug");
      const slugFromPath = window.location.pathname.match(/^\/cars\/([^/]+)\/?$/)?.[1];
      const slug = slugFromQuery || (slugFromPath && slugFromPath !== "detail" ? decodeURIComponent(slugFromPath) : "");

      if (!slug) {
        renderEmpty("Автомобиль не найден", "В ссылке нет slug объявления.");
      } else if (!apiUrl || apiUrl === placeholderUrl) {
        renderEmpty("Xano не настроен", "Укажи PUBLIC_XANO_API_URL для загрузки живых объявлений.");
      } else {
        fetch(`${apiUrl}/cars/${encodeURIComponent(slug)}`)
          .then((response) => {
            if (!response.ok) {
              throw new Error("Car not found");
            }

            return response.json();
          })
          .then((car) => {
            const images = Array.isArray(car.images) ? car.images : [];
            const galleryImages = [
              car.main_image_url,
              ...images.map((image: { image_url?: string }) => image.image_url),
            ]
              .filter(Boolean)
              .filter((value, index, array) => array.indexOf(value) === index)
              .slice(0, 5);
            const galleryImage = galleryImages[0] || "";
            const contactHref =
              normalizePhoneHref(car.seller_phone) ||
              (car.seller_email ? `mailto:${encodeURIComponent(String(car.seller_email))}` : "");
            const contactLabel = car.seller_phone
              ? `Связаться: ${escapeHtml(car.seller_phone)}`
              : car.seller_email
                ? `Написать: ${escapeHtml(car.seller_email)}`
                : "Контакты не указаны";

            root.innerHTML = `
              <nav class="breadcrumbs live-detail-breadcrumbs" aria-label="Хлебные крошки">
                <div class="breadcrumbs-inner">
                  <a href="/">Главная</a>
                  <span class="breadcrumb-separator" aria-hidden="true">/</span>
                  <a href="/cars">Авто</a>
                  <span class="breadcrumb-separator" aria-hidden="true">/</span>
                  <span aria-current="page">${escapeHtml(car.title)}</span>
                </div>
              </nav>
              <article class="detail-grid car-detail-grid">
                <div class="gallery car-slider" data-gallery>
                  <div class="gallery-stage">
                    ${
                      galleryImages.length > 1
                        ? `<button class="gallery-nav gallery-prev" type="button" aria-label="Предыдущее фото">‹</button>`
                        : ""
                    }
                    <button class="gallery-main-button" type="button" data-fullscreen-image="${escapeHtml(galleryImage)}" aria-label="Открыть фото на весь экран">
                      ${
                        galleryImage
                          ? `<img src="${escapeHtml(galleryImage)}" alt="${escapeHtml(car.title)}" />`
                          : `<div class="gallery-empty">Фото в Xano не добавлено</div>`
                      }
                    </button>
                    ${
                      galleryImages.length > 1
                        ? `<button class="gallery-nav gallery-next" type="button" aria-label="Следующее фото">›</button>`
                        : ""
                    }
                    <span class="gallery-count">${galleryImages.length > 0 ? `1 / ${galleryImages.length}` : "0 / 0"}</span>
                  </div>
                  <div class="gallery-strip">
                    ${
                      galleryImages.length > 0
                        ? galleryImages
                            .map((imageUrl: string, index: number) => `<button class="gallery-thumb${index === 0 ? " is-active" : ""}" type="button" data-slide-index="${index}" style="background-image:url('${escapeHtml(imageUrl)}');"></button>`)
                            .join("")
                        : "<span></span><span></span><span></span><span></span><span></span>"
                    }
                  </div>
                </div>
                <div class="detail-panel compact-detail-panel">
                  <span class="status-badge status-approved">Проверено модератором</span>
                  <h1>${escapeHtml(car.title)}</h1>
                  <p class="detail-price">${formatPrice(car.price, car.currency)}</p>
                  <dl class="spec-grid detail-spec-grid">
                    <div><dt>Год</dt><dd>${escapeHtml(car.year)}</dd></div>
                    <div><dt>Пробег</dt><dd>${Number(car.mileage || 0).toLocaleString("ru-RU")} км</dd></div>
                    <div><dt>Топливо</dt><dd>${escapeHtml(car.fuel_type)}</dd></div>
                    <div><dt>Коробка</dt><dd>${escapeHtml(car.transmission)}</dd></div>
                    <div><dt>Город</dt><dd>${escapeHtml(car.city)}, ${escapeHtml(car.country)}</dd></div>
                    <div><dt>Добавлено</dt><dd>${formatDate(car.created_at)}</dd></div>
                  </dl>
                  <p class="detail-description">${escapeHtml(car.description)}</p>
                  ${
                    contactHref
                      ? `<a class="button button-dark full-width" href="${contactHref}">${contactLabel}</a>`
                      : `<button class="button button-dark full-width" type="button" disabled>${contactLabel}</button>`
                  }
                </div>
              </article>
              <div class="lightbox" id="car-lightbox" hidden>
                <button class="lightbox-close" type="button" aria-label="Закрыть фото">×</button>
                ${
                  galleryImages.length > 1
                    ? `
                      <button class="lightbox-nav lightbox-prev" type="button" aria-label="Предыдущее фото">‹</button>
                      <button class="lightbox-nav lightbox-next" type="button" aria-label="Следующее фото">›</button>
                      <span class="lightbox-count">1 / ${galleryImages.length}</span>
                    `
                    : ""
                }
                <img src="${escapeHtml(galleryImage)}" alt="${escapeHtml(car.title)}" />
              </div>
            `;

            let activeSlideIndex = 0;
            const mainImage = root.querySelector(".gallery-main-button img");
            const mainButton = root.querySelector(".gallery-main-button");
            const galleryCount = root.querySelector(".gallery-count");
            const prevButton = root.querySelector(".gallery-prev");
            const nextButton = root.querySelector(".gallery-next");
            const lightbox = root.querySelector("#car-lightbox");
            const lightboxImage = lightbox?.querySelector("img");
            const closeButton = lightbox?.querySelector(".lightbox-close");
            const lightboxPrevButton = lightbox?.querySelector(".lightbox-prev");
            const lightboxNextButton = lightbox?.querySelector(".lightbox-next");
            const lightboxCount = lightbox?.querySelector(".lightbox-count");

            const updateLightbox = () => {
              if (lightboxImage instanceof HTMLImageElement) {
                lightboxImage.src = galleryImages[activeSlideIndex] || lightboxImage.src;
              }

              if (lightboxCount instanceof HTMLElement) {
                lightboxCount.textContent = `${activeSlideIndex + 1} / ${galleryImages.length}`;
              }
            };

            const updateSlide = (nextIndex: number) => {
              if (galleryImages.length === 0) {
                return;
              }

              activeSlideIndex = (nextIndex + galleryImages.length) % galleryImages.length;
              const imageUrl = galleryImages[activeSlideIndex];

              if (mainImage instanceof HTMLImageElement) {
                mainImage.src = imageUrl;
              }

              if (mainButton instanceof HTMLElement) {
                mainButton.dataset.fullscreenImage = imageUrl;
              }

              if (galleryCount instanceof HTMLElement) {
                galleryCount.textContent = `${activeSlideIndex + 1} / ${galleryImages.length}`;
              }

              updateLightbox();

              root.querySelectorAll(".gallery-thumb").forEach((thumb) => {
                if (thumb instanceof HTMLElement) {
                  thumb.classList.toggle("is-active", thumb.dataset.slideIndex === String(activeSlideIndex));
                }
              });
            };

            prevButton?.addEventListener("click", () => updateSlide(activeSlideIndex - 1));
            nextButton?.addEventListener("click", () => updateSlide(activeSlideIndex + 1));
            lightboxPrevButton?.addEventListener("click", () => updateSlide(activeSlideIndex - 1));
            lightboxNextButton?.addEventListener("click", () => updateSlide(activeSlideIndex + 1));

            root.querySelectorAll(".gallery-thumb").forEach((button) => {
              button.addEventListener("click", () => {
                if (button instanceof HTMLElement) {
                  updateSlide(Number(button.dataset.slideIndex || 0));
                }
              });
            });

            mainButton?.addEventListener("click", () => {
              const imageUrl =
                mainButton instanceof HTMLElement
                  ? mainButton.dataset.fullscreenImage || galleryImages[activeSlideIndex] || ""
                  : "";

              if (imageUrl && lightbox instanceof HTMLElement && lightboxImage instanceof HTMLImageElement) {
                updateLightbox();
                lightbox.hidden = false;
              }
            });

            closeButton?.addEventListener("click", () => {
              if (lightbox instanceof HTMLElement) {
                lightbox.hidden = true;
              }
            });

            lightbox?.addEventListener("click", (event) => {
              if (event.target === lightbox && lightbox instanceof HTMLElement) {
                lightbox.hidden = true;
              }
            });

            document.addEventListener("keydown", (event) => {
              if (!(lightbox instanceof HTMLElement) || lightbox.hidden) {
                return;
              }

              if (event.key === "Escape") {
                lightbox.hidden = true;
              }

              if (event.key === "ArrowLeft") {
                updateSlide(activeSlideIndex - 1);
              }

              if (event.key === "ArrowRight") {
                updateSlide(activeSlideIndex + 1);
              }
            });
          })
          .catch((error) => {
            console.error(error);
            renderEmpty("Автомобиль не найден", "Объявление не опубликовано или ещё не прошло модерацию.");
          });
      }
    }
  </script>
</BaseLayout>
