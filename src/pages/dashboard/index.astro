---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Личный кабинет">
  <section class="section page-hero">
    <div class="container narrow">
      <p class="eyebrow">Кабинет</p>
      <h1>Здесь будет личный кабинет пользователя</h1>
      <p class="lead">Позже здесь появятся авторизация Xano, управление объявлениями и загрузка изображений.</p>
      <div class="hero-actions">
        <a class="button button-light" href="/dashboard/listings">Мои объявления</a>
        <a class="button button-dark" href="/dashboard/new">Добавить объявление</a>
      </div>
      <p class="form-message" id="dashboard-auth-message">Проверяю вход...</p>
    </div>
  </section>
  <script>
    const token = window.localStorage.getItem("sitecraft_auto_market_auth_token");
    const userRaw = window.localStorage.getItem("sitecraft_auto_market_user");
    const message = document.querySelector("#dashboard-auth-message");

    if (!token) {
      window.location.href = `/login?next=${encodeURIComponent("/dashboard")}`;
    } else if (message instanceof HTMLElement) {
      try {
        const user = userRaw ? JSON.parse(userRaw) : null;
        message.textContent = user?.email
          ? `Вы вошли как ${user.email}.`
          : "Вы вошли в личный кабинет.";
      } catch {
        message.textContent = "Вы вошли в личный кабинет.";
      }
    }
  </script>
</BaseLayout>
