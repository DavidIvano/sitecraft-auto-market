---
import BaseLayout from "../../layouts/BaseLayout.astro";

const xanoApiUrl = import.meta.env.PUBLIC_XANO_API_URL;
---

<BaseLayout title="Личный кабинет">
  <section class="section page-hero">
    <div class="container narrow">
      <p class="eyebrow">Кабинет</p>
      <h1>Личный кабинет продавца</h1>
      <p class="lead">Здесь собраны ваши объявления, статусы модерации и быстрые действия.</p>
      <div class="hero-actions">
        <a class="button button-light" href="/dashboard/listings">Мои объявления</a>
        <a class="button button-dark" href="/dashboard/new">Добавить объявление</a>
      </div>
      <p class="form-message" id="dashboard-auth-message" data-api-url={xanoApiUrl}>Проверяю вход...</p>
    </div>
  </section>
  <script>
    import { clearAuth, getAuthToken, getAuthUser } from "../../lib/authClient";

    const token = getAuthToken();
    const userRaw = getAuthUser();
    const message = document.querySelector("#dashboard-auth-message");
    const apiUrl = message instanceof HTMLElement ? message.dataset.apiUrl : "";

    const clearAuthAndLogin = () => {
      clearAuth();
      window.location.href = `/login?next=${encodeURIComponent("/dashboard")}`;
    };

    if (!token) {
      window.location.href = `/login?next=${encodeURIComponent("/dashboard")}`;
    } else if (message instanceof HTMLElement) {
      fetch(`${apiUrl}/auth/me`, {
        headers: { Authorization: `Bearer ${token}` },
      })
        .then(async (response) => {
          if (!response.ok) {
            clearAuthAndLogin();
            return;
          }

          const payload = await response.json();
          const user = payload.user ?? userRaw;
          message.textContent = user?.email
            ? `Вы вошли как ${user.email}.`
            : "Вы вошли в личный кабинет.";
        })
        .catch(() => {
          clearAuthAndLogin();
        });
    }
  </script>
</BaseLayout>
