---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  bodyTypes,
  carBrands,
  carConditions,
  colors,
  doorCounts,
  drivetrains,
  fuelTypes,
  carModelsByBrand,
  seatCounts,
  sellerTypes,
  transmissions,
} from "../../data/carOptions";

const currentYear = new Date().getFullYear();
const years = Array.from({ length: currentYear - 1980 + 1 }, (_, index) => currentYear - index);

const xanoApiUrl = import.meta.env.PUBLIC_XANO_API_URL;
---

<BaseLayout title="Добавить объявление">
  <section class="section page-hero new-listing-hero">
    <div class="container">
      <p class="eyebrow">Новое объявление</p>
      <h1>Добавить автомобиль</h1>
      <p class="lead">
        Заполните основные данные, добавьте до пяти фото и перетащите их в нужном порядке.
        Первое фото станет главным в карточке и на странице автомобиля.
      </p>

      <form class="listing-form listing-form-enhanced" id="new-listing-form" data-api-url={xanoApiUrl}>
        <div class="listing-workspace">
          <div class="listing-main-column">
        <fieldset class="form-section form-section-highlight">
          <div class="section-heading">
            <span class="section-step">1</span>
            <div>
              <h2>Автомобиль</h2>
              <p>Сначала выберите марку. После этого появятся только модели этой марки.</p>
            </div>
          </div>
          <div class="form-grid">
            <label>
              <span>Марка автомобиля</span>
              <select name="brand" required data-brand-select>
                <option value="">Выберите марку</option>
                {carBrands.map((brand) => <option value={brand}>{brand}</option>)}
              </select>
            </label>

            <label>
              <span>Модель автомобиля</span>
              <select name="model" required data-model-select disabled>
                <option value="">Сначала выберите марку</option>
              </select>
            </label>

            <label>
              <span>Год выпуска</span>
              <select name="year" required>
                <option value="">Выберите год</option>
                {years.map((year) => <option value={year}>{year}</option>)}
              </select>
            </label>

            <label>
              <span>Цена</span>
              <input type="number" name="price" min="0" step="1" placeholder="25000" required />
            </label>

            <label>
              <span>Пробег</span>
              <input type="number" name="mileage" min="0" step="1" placeholder="85000" required />
            </label>

            <label>
              <span>Город / местоположение</span>
              <input type="text" name="location" placeholder="Берлин" required />
            </label>
          </div>
        </fieldset>

        <fieldset class="form-section">
          <div class="section-heading">
            <span class="section-step">2</span>
            <div>
              <h2>Характеристики</h2>
              <p>Эти параметры помогают покупателю быстро понять, подходит ли автомобиль.</p>
            </div>
          </div>
          <div class="form-grid">
            <label>
              <span>Тип кузова</span>
              <select name="bodyType" required>
                <option value="">Выберите тип кузова</option>
                {bodyTypes.map((item) => <option value={item}>{item}</option>)}
              </select>
            </label>

            <label>
              <span>Вид топлива</span>
              <select name="fuelType" required>
                <option value="">Выберите топливо</option>
                {fuelTypes.map((item) => <option value={item}>{item}</option>)}
              </select>
            </label>

            <label>
              <span>Коробка передач</span>
              <select name="transmission" required>
                <option value="">Выберите коробку</option>
                {transmissions.map((item) => <option value={item}>{item}</option>)}
              </select>
            </label>

            <label>
              <span>Привод</span>
              <select name="drivetrain" required>
                <option value="">Выберите привод</option>
                {drivetrains.map((item) => <option value={item}>{item}</option>)}
              </select>
            </label>

            <label>
              <span>Количество дверей</span>
              <select name="doors" required>
                <option value="">Выберите двери</option>
                {doorCounts.map((item) => <option value={item}>{item}</option>)}
              </select>
            </label>

            <label>
              <span>Количество мест</span>
              <select name="seats" required>
                <option value="">Выберите места</option>
                {seatCounts.map((item) => <option value={item}>{item}</option>)}
              </select>
            </label>

            <label>
              <span>Цвет</span>
              <select name="color" required>
                <option value="">Выберите цвет</option>
                {colors.map((item) => <option value={item}>{item}</option>)}
              </select>
            </label>

            <label>
              <span>Состояние автомобиля</span>
              <select name="condition" required>
                <option value="">Выберите состояние</option>
                {carConditions.map((item) => <option value={item}>{item}</option>)}
              </select>
            </label>

            <label>
              <span>Тип продавца</span>
              <select name="sellerType" required>
                <option value="">Выберите тип продавца</option>
                {sellerTypes.map((item) => <option value={item}>{item}</option>)}
              </select>
            </label>

            <label>
              <span>VIN / номер кузова</span>
              <input type="text" name="vin" placeholder="Опционально" />
            </label>
          </div>
        </fieldset>

        <fieldset class="form-section">
          <div class="section-heading">
            <span class="section-step">3</span>
            <div>
              <h2>Продавец</h2>
              <p>Кнопка «Связаться» будет использовать телефон, если он указан, иначе email.</p>
            </div>
          </div>
          <div class="form-grid">
            <label>
              <span>Имя продавца</span>
              <input type="text" name="sellerName" placeholder="Ваше имя" required />
            </label>

            <label>
              <span>Телефон продавца</span>
              <input type="tel" name="sellerPhone" placeholder="+49 ..." />
            </label>

            <label>
              <span>Email продавца</span>
              <input type="email" name="sellerEmail" placeholder="name@example.com" />
            </label>
          </div>
        </fieldset>

        <fieldset class="form-section photo-form-section">
          <div class="section-heading">
            <span class="section-step">4</span>
            <div>
              <h2>Фото и описание</h2>
              <p>До 5 изображений. Перетащите карточки, чтобы выбрать главное фото первым.</p>
            </div>
          </div>
          <div class="form-grid">
            <div class="full-field photo-uploader" data-photo-uploader>
              <input
                class="photo-input"
                id="photo-input"
                type="file"
                name="photos"
                accept="image/avif,image/webp,image/jpeg,image/png"
                multiple
                data-max-files="5"
              />
              <label class="photo-dropzone" for="photo-input" data-photo-dropzone>
                <span class="photo-dropzone-icon">+</span>
                <strong>Перетащите фото сюда или выберите файлы</strong>
                <small>AVIF, PNG, JPG или WEBP. Первое изображение будет главным.</small>
              </label>
              <div class="photo-preview-toolbar">
                <span id="photo-count">0 / 5 фото</span>
                <button class="button button-light button-small" type="button" id="photo-clear" hidden>Очистить фото</button>
              </div>
              <div class="photo-preview-grid" id="photo-preview-grid" aria-live="polite">
                <div class="photo-empty-state">Пока фото не выбраны.</div>
              </div>
            </div>

            <label class="full-field">
              <span>Краткое описание</span>
              <textarea name="description" rows="6" placeholder="Опишите состояние, историю обслуживания и важные детали"></textarea>
            </label>
          </div>
        </fieldset>
          </div>

          <aside class="listing-side-panel" aria-label="Проверка объявления">
            <div class="side-panel-card">
              <p class="eyebrow">Публикация</p>
              <h2>Проверьте перед отправкой</h2>
              <ul class="publish-checklist">
                <li>Марка и модель выбраны правильно.</li>
                <li>Главное фото стоит первым.</li>
                <li>Телефон или email заполнен.</li>
                <li>Описание без лишних личных данных.</li>
              </ul>
              <button class="button button-dark full-width" type="submit">Добавить объявление</button>
              <p class="form-message" id="form-message">
                После отправки объявление будет подготовлено к модерации.
              </p>
            </div>
          </aside>
        </div>
      </form>

      <script is:inline type="application/json" id="car-model-data" set:html={JSON.stringify(carModelsByBrand)} />

      <script>
        import { clearAuth, getAuthToken, rememberNext } from "../../lib/authClient";

        const authToken = getAuthToken();
        const form = document.querySelector("#new-listing-form");
        const message = document.querySelector("#form-message");
        const photoInput = document.querySelector('input[name="photos"]');
        const photoDropzone = document.querySelector("[data-photo-dropzone]");
        const photoPreviewGrid = document.querySelector("#photo-preview-grid");
        const photoCount = document.querySelector("#photo-count");
        const photoClear = document.querySelector("#photo-clear");
        const brandSelect = document.querySelector("[data-brand-select]");
        const modelSelect = document.querySelector("[data-model-select]");
        const modelDataElement = document.querySelector("#car-model-data");
        const carModelsByBrand = modelDataElement?.textContent
          ? JSON.parse(modelDataElement.textContent) as Record<string, string[]>
          : {};
        const selectedPhotos: File[] = [];
        const photoUrls = new Map<File, string>();

        function clearOldAuthAndRelogin() {
          clearAuth();
          rememberNext("/dashboard/new");
          window.location.href = `/login?next=${encodeURIComponent("/dashboard/new")}`;
        }

        function isWrongTokenError(value: string) {
          return value.includes("different object type") || value.includes("ERROR_CODE_UNAUTHORIZED");
        }

        function getAuthObjectError() {
          return "Xano endpoint создания объявления всё ещё настроен на старую таблицу авторизации. В Xano для POST /cars, PATCH /cars/{id}/submit и GET /dashboard/listings нужно поставить auth = automarket_users.";
        }

        function getXanoListingError(value: string) {
          if (value.includes("car.user_id") || value.includes("Unable to locate var")) {
            return "Объявление создано как черновик, но Xano не может отправить его на модерацию: в live-таблице car_listings нет поля user_id. Добавь поле user_id со связью на automarket_users, затем сохрани таблицу и endpoint.";
          }

          return value;
        }

        function setMessage(value: string) {
          if (message instanceof HTMLElement) {
            message.textContent = value;
          }
        }

        function escapeHtml(value: string) {
          return value
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll('"', "&quot;")
            .replaceAll("'", "&#039;");
        }

        function syncPhotoInput() {
          if (!(photoInput instanceof HTMLInputElement)) {
            return;
          }

          const transfer = new DataTransfer();
          selectedPhotos.forEach((file) => transfer.items.add(file));
          photoInput.files = transfer.files;
        }

        function renderPhotoPreview() {
          if (!(photoPreviewGrid instanceof HTMLElement)) {
            return;
          }

          const maxFiles = photoInput instanceof HTMLInputElement ? Number(photoInput.dataset.maxFiles || 5) : 5;

          if (photoCount instanceof HTMLElement) {
            photoCount.textContent = `${selectedPhotos.length} / ${maxFiles} фото`;
          }

          if (photoClear instanceof HTMLButtonElement) {
            photoClear.hidden = selectedPhotos.length === 0;
          }

          if (selectedPhotos.length === 0) {
            photoPreviewGrid.innerHTML = `<div class="photo-empty-state">Пока фото не выбраны.</div>`;
            return;
          }

          photoPreviewGrid.innerHTML = selectedPhotos
            .map((file, index) => {
              let url = photoUrls.get(file);

              if (!url) {
                url = URL.createObjectURL(file);
                photoUrls.set(file, url);
              }

              return `
                <article class="photo-preview-card${index === 0 ? " is-main" : ""}" draggable="true" data-photo-index="${index}">
                  <img src="${url}" alt="Фото ${index + 1}" />
                  <div class="photo-preview-actions">
                    <span>${index === 0 ? "Главное фото" : `Фото ${index + 1}`}</span>
                    <div class="photo-preview-buttons">
                      ${index === 0 ? "" : `<button type="button" data-make-main-photo="${index}">Главным</button>`}
                      <button type="button" aria-label="Удалить фото ${index + 1}" data-remove-photo="${index}">×</button>
                    </div>
                  </div>
                </article>
              `;
            })
            .join("");
        }

        function setPhotoFiles(files: File[]) {
          if (!(photoInput instanceof HTMLInputElement)) {
            return;
          }

          const maxFiles = Number(photoInput.dataset.maxFiles || 5);
          const imageFiles = files.filter((file) => file.type.startsWith("image/"));
          const remainingSlots = Math.max(maxFiles - selectedPhotos.length, 0);
          const nextFiles = imageFiles.slice(0, remainingSlots);

          selectedPhotos.push(...nextFiles);

          if (imageFiles.length > remainingSlots) {
            setMessage(`Можно загрузить максимум ${maxFiles} фото. Лишние изображения не добавлены.`);
          }

          syncPhotoInput();
          renderPhotoPreview();
        }

        function movePhoto(fromIndex: number, toIndex: number) {
          if (fromIndex === toIndex || fromIndex < 0 || toIndex < 0 || fromIndex >= selectedPhotos.length || toIndex >= selectedPhotos.length) {
            return;
          }

          const [file] = selectedPhotos.splice(fromIndex, 1);
          selectedPhotos.splice(toIndex, 0, file);
          syncPhotoInput();
          renderPhotoPreview();
        }

        function removePhoto(index: number) {
          const [file] = selectedPhotos.splice(index, 1);

          if (file) {
            const url = photoUrls.get(file);
            if (url) {
              URL.revokeObjectURL(url);
            }
            photoUrls.delete(file);
          }

          syncPhotoInput();
          renderPhotoPreview();
        }

        function clearPhotos() {
          selectedPhotos.splice(0, selectedPhotos.length);
          photoUrls.forEach((url) => URL.revokeObjectURL(url));
          photoUrls.clear();
          syncPhotoInput();
          renderPhotoPreview();
        }

        async function convertImageToJpeg(file: File, index: number) {
          const bitmap = await createImageBitmap(file);
          const maxSize = 1920;
          const scale = Math.min(1, maxSize / Math.max(bitmap.width, bitmap.height));
          const width = Math.max(1, Math.round(bitmap.width * scale));
          const height = Math.max(1, Math.round(bitmap.height * scale));
          const canvas = document.createElement("canvas");
          canvas.width = width;
          canvas.height = height;

          const context = canvas.getContext("2d");
          if (!context) {
            bitmap.close();
            throw new Error("Браузер не смог подготовить изображение к загрузке.");
          }

          context.drawImage(bitmap, 0, 0, width, height);
          bitmap.close();

          const blob = await new Promise<Blob | null>((resolve) => {
            canvas.toBlob(resolve, "image/jpeg", 0.88);
          });

          if (!blob) {
            throw new Error("Не удалось конвертировать изображение перед отправкой.");
          }

          const safeName = file.name.replace(/\.[^.]+$/, "") || `car-photo-${index + 1}`;
          return new File([blob], `${safeName}.jpg`, {
            type: "image/jpeg",
            lastModified: Date.now(),
          });
        }

        function updateModelsForBrand() {
          if (!(brandSelect instanceof HTMLSelectElement) || !(modelSelect instanceof HTMLSelectElement)) {
            return;
          }

          const brand = brandSelect.value;
          const models = carModelsByBrand[brand] || [];

          modelSelect.innerHTML = brand
            ? `<option value="">Выберите модель</option>${models.map((model) => `<option value="${escapeHtml(model)}">${escapeHtml(model)}</option>`).join("")}`
            : `<option value="">Сначала выберите марку</option>`;
          modelSelect.disabled = !brand;
        }

        if (!authToken) {
          window.location.href = `/login?next=${encodeURIComponent("/dashboard/new")}`;
        }

        async function validateAuthToken() {
          const apiUrl = form instanceof HTMLFormElement ? form.dataset.apiUrl : undefined;

          if (!authToken || !apiUrl) {
            clearOldAuthAndRelogin();
            return;
          }

          try {
            const response = await fetch(`${apiUrl}/auth/me`, {
              headers: {
                Authorization: `Bearer ${authToken}`,
              },
            });

            if (!response.ok) {
              clearOldAuthAndRelogin();
            }
          } catch {
            clearOldAuthAndRelogin();
          }
        }

        validateAuthToken();

        brandSelect?.addEventListener("change", updateModelsForBrand);

        photoInput?.addEventListener("change", () => {
          if (photoInput instanceof HTMLInputElement) {
            setPhotoFiles(Array.from(photoInput.files || []));
          }
        });

        photoClear?.addEventListener("click", clearPhotos);

        photoDropzone?.addEventListener("dragover", (event) => {
          event.preventDefault();
          if (photoDropzone instanceof HTMLElement) {
            photoDropzone.classList.add("is-dragging");
          }
        });

        photoDropzone?.addEventListener("dragleave", () => {
          if (photoDropzone instanceof HTMLElement) {
            photoDropzone.classList.remove("is-dragging");
          }
        });

        photoDropzone?.addEventListener("drop", (event) => {
          event.preventDefault();
          const dragEvent = event as DragEvent;
          if (photoDropzone instanceof HTMLElement) {
            photoDropzone.classList.remove("is-dragging");
          }

          setPhotoFiles(Array.from(dragEvent.dataTransfer?.files || []));
        });

        photoPreviewGrid?.addEventListener("dragstart", (event) => {
          const dragEvent = event as DragEvent;
          const card = event.target instanceof HTMLElement ? event.target.closest("[data-photo-index]") : null;

          if (card instanceof HTMLElement && dragEvent.dataTransfer) {
            dragEvent.dataTransfer.setData("text/plain", card.dataset.photoIndex || "0");
          }
        });

        photoPreviewGrid?.addEventListener("dragover", (event) => {
          event.preventDefault();
        });

        photoPreviewGrid?.addEventListener("drop", (event) => {
          event.preventDefault();
          const dragEvent = event as DragEvent;
          const target = event.target instanceof HTMLElement ? event.target.closest("[data-photo-index]") : null;
          const fromIndex = Number(dragEvent.dataTransfer?.getData("text/plain") || -1);
          const toIndex = target instanceof HTMLElement ? Number(target.dataset.photoIndex || -1) : -1;
          movePhoto(fromIndex, toIndex);
        });

        photoPreviewGrid?.addEventListener("click", (event) => {
          const button = event.target instanceof HTMLElement ? event.target.closest("[data-remove-photo]") : null;
          const makeMainButton = event.target instanceof HTMLElement ? event.target.closest("[data-make-main-photo]") : null;

          if (makeMainButton instanceof HTMLElement) {
            movePhoto(Number(makeMainButton.dataset.makeMainPhoto || -1), 0);
            return;
          }

          if (button instanceof HTMLElement) {
            removePhoto(Number(button.dataset.removePhoto || -1));
          }
        });

        async function submitListing(payload: FormData) {
          const apiUrl = form instanceof HTMLFormElement ? form.dataset.apiUrl : undefined;

          if (!apiUrl) {
            throw new Error("Xano API URL не настроен.");
          }

          const createResponse = await fetch(`${apiUrl}/cars`, {
            method: "POST",
            headers: {
              Authorization: `Bearer ${authToken}`,
            },
            body: payload,
          });

          if (!createResponse.ok) {
            const errorText = await createResponse.text();
            if (isWrongTokenError(errorText)) {
              throw new Error(getAuthObjectError());
            }
            throw new Error(errorText || "Xano не сохранил объявление.");
          }

          const createdCar = await createResponse.json();
          const id = createdCar?.id;

          if (!id) {
            throw new Error("Xano сохранил объявление, но не вернул ID.");
          }

          const submitResponse = await fetch(`${apiUrl}/cars/${id}/submit`, {
            method: "PATCH",
            headers: {
              Authorization: `Bearer ${authToken}`,
            },
          });

          if (!submitResponse.ok) {
            const errorText = await submitResponse.text();
            if (isWrongTokenError(errorText)) {
              throw new Error(getAuthObjectError());
            }
            throw new Error(getXanoListingError(errorText) || "Объявление сохранено, но не отправлено на модерацию.");
          }

          return submitResponse.json();
        }

        form?.addEventListener("submit", async (event) => {
          event.preventDefault();

          if (!(form instanceof HTMLFormElement) || !(message instanceof HTMLElement)) {
            return;
          }

          syncPhotoInput();
          const formData = new FormData(form);
          const sellerPhone = String(formData.get("sellerPhone") || "").trim();
          const sellerEmail = String(formData.get("sellerEmail") || "").trim();

          if (!sellerPhone && !sellerEmail) {
            setMessage("Укажите телефон или email продавца.");
            return;
          }

          const brand = String(formData.get("brand") || "");
          const model = String(formData.get("model") || "");
          const year = Number(formData.get("year"));
          const city = String(formData.get("location") || "");

          const payload = new FormData();
          payload.set("title", `${brand} ${model} ${year}`.trim());
          payload.set("brand", brand);
          payload.set("model", model);
          payload.set("year", String(year));
          payload.set("price", String(Number(formData.get("price"))));
          payload.set("mileage", String(Number(formData.get("mileage"))));
          payload.set("fuel_type", String(formData.get("fuelType") || ""));
          payload.set("transmission", String(formData.get("transmission") || ""));
          payload.set("currency", "EUR");
          payload.set("city", city);
          payload.set("country", "Германия");
          payload.set("seller_name", String(formData.get("sellerName") || "").trim());
          payload.set("seller_phone", sellerPhone);
          payload.set("seller_email", sellerEmail);
          payload.set(
            "description",
            [
              String(formData.get("description") || ""),
              `Кузов: ${String(formData.get("bodyType") || "не указан")}`,
              `Привод: ${String(formData.get("drivetrain") || "не указан")}`,
              `Двери: ${String(formData.get("doors") || "не указано")}`,
              `Места: ${String(formData.get("seats") || "не указано")}`,
              `Цвет: ${String(formData.get("color") || "не указан")}`,
              `Состояние: ${String(formData.get("condition") || "не указано")}`,
              `Тип продавца: ${String(formData.get("sellerType") || "не указан")}`,
              `VIN: ${String(formData.get("vin") || "не указан")}`,
              `Продавец: ${String(formData.get("sellerName") || "не указан")}`,
              `Телефон: ${sellerPhone || "не указан"}`,
              `Email: ${sellerEmail || "не указан"}`,
            ]
              .filter(Boolean)
              .join("\n"),
          );

          const photoFiles = [...selectedPhotos];

          if (photoFiles.length > 5) {
            setMessage("Можно загрузить максимум 5 фото.");
            return;
          }

          try {
            if (photoFiles.length > 0) {
              setMessage("Подготавливаю фото к загрузке...");
            }

            for (const [index, file] of photoFiles.entries()) {
              if (file instanceof File && file.size > 0) {
                const uploadFile = await convertImageToJpeg(file, index);
                payload.append("photos", uploadFile);
                payload.set(`photo_${index + 1}`, uploadFile);
              }
            }

            setMessage("Сохраняю объявление и отправляю на модерацию...");
            await submitListing(payload);

            setMessage("Объявление отправлено на модерацию. Оно появится в админ-панели.");
            form.reset();
            clearPhotos();
            updateModelsForBrand();
          } catch (error) {
            console.error(error);
            setMessage(
              error instanceof Error
                ? `Не удалось сохранить объявление: ${error.message}`
                : "Не удалось сохранить объявление.",
            );
          }
        });
      </script>
    </div>
  </section>
</BaseLayout>
