---
import StatusBadge from "../../components/StatusBadge.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { CarListingStatus } from "../../lib/types";

const xanoApiUrl = import.meta.env.PUBLIC_XANO_API_URL;

const listings: { title: string; status: CarListingStatus }[] = [
  { title: "BMW 530i M Sport", status: "draft" },
  { title: "Audi Q5 Quattro", status: "pending_review" },
  { title: "Mercedes-Benz C300", status: "approved" },
  { title: "Porsche Macan", status: "rejected" },
];
---

<BaseLayout title="Мои объявления">
  <section class="section page-hero">
    <div class="container">
      <p class="eyebrow">Кабинет</p>
      <h1>Мои объявления</h1>
      <div class="list-panel" id="dashboard-listings" data-api-url={xanoApiUrl}>
        {listings.map((listing) => (
          <div class="list-row">
            <strong>{listing.title}</strong>
            <StatusBadge status={listing.status} />
          </div>
        ))}
      </div>
      <p class="form-message" id="dashboard-listings-message">Проверяю вход...</p>
    </div>
  </section>
  <script>
    const token = window.localStorage.getItem("sitecraft_auto_market_auth_token");
    const list = document.querySelector("#dashboard-listings");
    const message = document.querySelector("#dashboard-listings-message");

    if (!token) {
      window.location.href = `/login?next=${encodeURIComponent("/dashboard/listings")}`;
    } else if (list instanceof HTMLElement && message instanceof HTMLElement) {
      const apiUrl = list.dataset.apiUrl;

      fetch(`${apiUrl}/dashboard/listings`, {
        headers: { Authorization: `Bearer ${token}` },
      })
        .then(async (response) => {
          if (!response.ok) {
            window.localStorage.removeItem("sitecraft_auto_market_auth_token");
            window.localStorage.removeItem("sitecraft_auto_market_user");
            window.location.href = `/login?next=${encodeURIComponent("/dashboard/listings")}`;
            return;
          }

          const cars = await response.json();

          if (!Array.isArray(cars) || cars.length === 0) {
            list.innerHTML = '<div class="list-row"><strong>У вас пока нет объявлений.</strong></div>';
            message.textContent = "После добавления автомобиля он появится здесь.";
            return;
          }

          list.innerHTML = cars
            .map(
              (car) => `
                <div class="list-row">
                  <strong>${String(car.title ?? "Без названия")}</strong>
                  <span class="status-badge status-${String(car.status ?? "draft")}">${String(car.status ?? "draft")}</span>
                </div>
              `,
            )
            .join("");
          message.textContent = `Загружено объявлений: ${cars.length}.`;
        })
        .catch(() => {
          message.textContent = "Не удалось загрузить объявления.";
        });
    }
  </script>
</BaseLayout>
