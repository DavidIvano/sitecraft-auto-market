---
import BaseLayout from "../layouts/BaseLayout.astro";
import { carBrands, fuelTypes, transmissions } from "../data/carOptions";

const xanoApiUrl = import.meta.env.PUBLIC_XANO_API_URL;
const placeholderApiUrl = "https://your-xano-api-url.com/api:YOUR_GROUP";
---

<BaseLayout title="Премиальная доска объявлений авто">
  <section class="market-hero">
    <div class="market-hero-media" aria-hidden="true">
      <img id="home-hero-image" alt="" hidden />
    </div>
    <div class="container market-hero-inner">
      <div class="market-hero-copy">
        <p class="eyebrow">SiteCraft Auto Market</p>
        <h1>Найди свой автомобиль</h1>
        <p class="lead">Свежие проверенные автомобили, ручная модерация и быстрый подбор по главным параметрам.</p>
      </div>

      <div
        class="home-search-panel"
        id="home-search-panel"
        data-api-url={xanoApiUrl}
        data-placeholder-url={placeholderApiUrl}
      >
        <div class="search-tabs" aria-label="Категория транспорта">
          <button class="search-tab is-active" type="button">Авто</button>
          <button class="search-tab" type="button">Электро</button>
          <button class="search-tab" type="button">Премиум</button>
        </div>
        <form class="market-search" id="home-search-form">
          <label>
            Марка
            <select name="brand">
              <option value="">Неважно</option>
              {carBrands.map((brand) => <option value={brand}>{brand}</option>)}
            </select>
          </label>
          <label>
            Модель
            <input name="model" type="search" placeholder="Например, A4" />
          </label>
          <label>
            Цена до
            <input name="price" type="number" min="0" step="100" placeholder="4000" />
          </label>
          <label>
            Год от
            <input name="year" type="number" min="1950" max="2030" placeholder="2018" />
          </label>
          <label>
            Пробег до
            <input name="mileage" type="number" min="0" step="1000" placeholder="150000" />
          </label>
          <label>
            Топливо
            <select name="fuel">
              <option value="">Неважно</option>
              {fuelTypes.map((fuel) => <option value={fuel}>{fuel}</option>)}
            </select>
          </label>
          <label>
            Трансмиссия
            <select name="transmission">
              <option value="">Неважно</option>
              {transmissions.map((transmission) => <option value={transmission}>{transmission}</option>)}
            </select>
          </label>
          <label>
            Город
            <input name="city" type="search" placeholder="Берлин" />
          </label>
          <div class="search-actions">
            <button class="button button-accent" id="home-search-button" type="submit">
              Смотреть объявления
            </button>
            <button class="button button-ghost" id="home-reset-button" type="button">Сбросить</button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <section class="section home-categories">
    <div class="container">
      <div class="section-heading row-heading">
        <div>
          <p class="eyebrow">Подборки</p>
          <h2>Категории авто</h2>
        </div>
        <div class="slider-controls" aria-label="Управление слайдером категорий">
          <button class="slider-button" id="category-prev" type="button" aria-label="Предыдущие категории">‹</button>
          <button class="slider-button" id="category-next" type="button" aria-label="Следующие категории">›</button>
        </div>
      </div>
      <div class="category-carousel" aria-label="Категории автомобилей">
        <div class="category-track" id="home-category-track">
          <div class="category-loading">Подбираю категории автомобилей...</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Последние объявления</p>
          <h2>Свежие автомобили</h2>
          <p class="section-subtitle">Последние опубликованные автомобили с актуальными фотографиями и контактами продавцов.</p>
        </div>
        <a href="/cars">Все авто</a>
      </div>
      <div
        class="cards-grid"
        id="home-live-cars-grid"
        hidden
      >
      </div>
      <div class="empty-state" id="home-loading-state">
        <h3>Загружаю свежие автомобили</h3>
        <p>Подбираю последние опубликованные объявления.</p>
      </div>
      <p class="form-message" id="home-live-cars-message"></p>
    </div>
  </section>

  <script>
    const liveGrid = document.querySelector("#home-live-cars-grid");
    const loadingState = document.querySelector("#home-loading-state");
    const message = document.querySelector("#home-live-cars-message");
    const searchPanel = document.querySelector("#home-search-panel");
    const searchForm = document.querySelector("#home-search-form");
    const resetButton = document.querySelector("#home-reset-button");
    const searchButton = document.querySelector("#home-search-button");
    const heroImage = document.querySelector("#home-hero-image");
    const categoryTrack = document.querySelector("#home-category-track");
    const categoryPrev = document.querySelector("#category-prev");
    const categoryNext = document.querySelector("#category-next");
    let allCars: Array<Record<string, unknown>> = [];

    const formatPrice = (price: unknown, currency: string) =>
      new Intl.NumberFormat("ru-RU", {
        style: "currency",
        currency: currency || "EUR",
        maximumFractionDigits: 0,
      }).format(Number(price || 0));

    const escapeHtml = (value: unknown) =>
      String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");

    const toDate = (value: unknown) => {
      if (!value) {
        return null;
      }

      const stringValue = String(value);
      const date = typeof value === "number" || /^\d+$/.test(stringValue)
        ? new Date(Number(value))
        : new Date(stringValue);

      return Number.isNaN(date.getTime()) ? null : date;
    };

    const formatDate = (value: unknown) => {
      const date = toDate(value);

      if (!date) {
        return "дата уточняется";
      }

      return new Intl.DateTimeFormat("ru-RU", {
        dateStyle: "medium",
        timeStyle: "short",
      }).format(date);
    };

    const newestFirst = (cars: Array<Record<string, unknown>>) =>
      [...cars].sort((left, right) => {
        const leftTime = toDate(left.created_at)?.getTime() ?? 0;
        const rightTime = toDate(right.created_at)?.getTime() ?? 0;
        return rightTime - leftTime;
      });

    const carImageMarkup = (car: Record<string, unknown>) => {
      const imageUrl = String(car.main_image_url || "");

      if (!imageUrl) {
        return `<div class="car-image car-image-empty">Фото пока не добавлено</div>`;
      }

      return `<img src="${escapeHtml(imageUrl)}" alt="${escapeHtml(car.title)}" class="car-image" loading="lazy" />`;
    };

    const renderCarCard = (car: Record<string, unknown>) => {
      const slug = encodeURIComponent(String(car.slug ?? ""));
      const title = escapeHtml(car.title);

      return `
        <article class="car-card">
          <a class="car-image-link" href="/cars/${slug}" aria-label="Смотреть ${title}">
            ${carImageMarkup(car)}
          </a>
          <div class="car-card-body">
            <div class="car-card-top">
              <h3>${title}</h3>
              <span class="status-badge status-approved">Проверено модератором</span>
            </div>
            <p class="car-price">${formatPrice(car.price, String(car.currency || "EUR"))}</p>
            <p class="car-date">Добавлено: ${formatDate(car.created_at)}</p>
            <dl class="car-meta">
              <div><dt>Год</dt><dd>${escapeHtml(car.year)}</dd></div>
              <div><dt>Пробег</dt><dd>${Number(car.mileage || 0).toLocaleString("ru-RU")} км</dd></div>
              <div><dt>Город</dt><dd>${escapeHtml(car.city)}</dd></div>
            </dl>
            <a class="button button-light full-width" href="/cars/${slug}">Смотреть</a>
          </div>
        </article>
      `;
    };

    const categoryDefinitions = [
      {
        title: "Семейные",
        text: "Практичные автомобили для города и поездок.",
        match: (car: Record<string, unknown>) =>
          /универсал|минивэн|suv|кроссовер|внедорожник/i.test(String(car.description || "")),
      },
      {
        title: "Первые авто",
        text: "Недорогие варианты для старта.",
        match: (car: Record<string, unknown>) => Number(car.price || 0) > 0 && Number(car.price || 0) <= 5000,
      },
      {
        title: "Премиум",
        text: "BMW, Audi, Mercedes-Benz и другие сильные варианты.",
        match: (car: Record<string, unknown>) =>
          /bmw|audi|mercedes|porsche|lexus|land rover/i.test(String(car.brand || "")),
      },
      {
        title: "Электро",
        text: "Электромобили и современные гибриды.",
        match: (car: Record<string, unknown>) => /электро|hybrid|гибрид/i.test(String(car.fuel_type || "")),
      },
      {
        title: "Свежие",
        text: "Последние опубликованные объявления.",
        match: () => true,
      },
      {
        title: "С фото",
        text: "Объявления с загруженными изображениями.",
        match: (car: Record<string, unknown>) => Boolean(car.main_image_url),
      },
    ];

    const pickCategoryCar = (
      cars: Array<Record<string, unknown>>,
      match: (car: Record<string, unknown>) => boolean,
    ) => cars.find((car) => match(car) && Boolean(car.main_image_url)) || cars.find((car) => match(car)) || cars[0];

    const renderCategories = (cars: Array<Record<string, unknown>>) => {
      if (!(categoryTrack instanceof HTMLElement)) {
        return;
      }

      if (cars.length === 0) {
        categoryTrack.innerHTML = `<div class="category-loading">Категории появятся после публикации объявлений.</div>`;
        return;
      }

      categoryTrack.innerHTML = categoryDefinitions
        .map((category) => {
          const car = pickCategoryCar(cars, category.match);
          const imageUrl = String(car?.main_image_url || "");
          const slug = car?.slug ? `/cars/${encodeURIComponent(String(car.slug))}` : "/cars";
          const meta = car
            ? `${escapeHtml(car.brand)} ${escapeHtml(car.model)} · ${formatPrice(car.price, String(car.currency || "EUR"))}`
            : "Смотреть объявления";

          return `
            <a class="category-slide" href="${slug}" aria-label="${escapeHtml(category.title)}">
              ${
                imageUrl
                  ? `<img src="${escapeHtml(imageUrl)}" alt="" loading="lazy" />`
                  : `<div class="category-slide-empty">Фото пока не добавлено</div>`
              }
              <div class="category-slide-body">
                <h3>${escapeHtml(category.title)}</h3>
                <p>${escapeHtml(category.text)}</p>
                <span>${meta}</span>
              </div>
            </a>
          `;
        })
        .join("");
    };

    const scrollCategories = (direction: number) => {
      if (!(categoryTrack instanceof HTMLElement)) {
        return;
      }

      categoryTrack.scrollBy({
        left: direction * Math.max(260, categoryTrack.clientWidth * 0.8),
        behavior: "smooth",
      });
    };

    categoryPrev?.addEventListener("click", () => scrollCategories(-1));
    categoryNext?.addEventListener("click", () => scrollCategories(1));

    const applyHeroImage = (cars: Array<Record<string, unknown>>) => {
      const firstCarWithImage = cars.find((car) => Boolean(car.main_image_url));

      if (heroImage instanceof HTMLImageElement && firstCarWithImage?.main_image_url) {
        heroImage.src = String(firstCarWithImage.main_image_url);
        heroImage.hidden = false;
      }
    };

    const matchesFilters = (car: Record<string, unknown>, formData: FormData) => {
      const brand = String(formData.get("brand") || "").toLowerCase();
      const model = String(formData.get("model") || "").toLowerCase();
      const fuel = String(formData.get("fuel") || "").toLowerCase();
      const transmission = String(formData.get("transmission") || "").toLowerCase();
      const city = String(formData.get("city") || "").toLowerCase();
      const maxPrice = Number(formData.get("price") || 0);
      const minYear = Number(formData.get("year") || 0);
      const maxMileage = Number(formData.get("mileage") || 0);

      return (
        (!brand || String(car.brand || "").toLowerCase() === brand) &&
        (!model || String(car.model || "").toLowerCase().includes(model)) &&
        (!fuel || String(car.fuel_type || "").toLowerCase() === fuel) &&
        (!transmission || String(car.transmission || "").toLowerCase() === transmission) &&
        (!city || String(car.city || "").toLowerCase().includes(city)) &&
        (!maxPrice || Number(car.price || 0) <= maxPrice) &&
        (!minYear || Number(car.year || 0) >= minYear) &&
        (!maxMileage || Number(car.mileage || 0) <= maxMileage)
      );
    };

    const renderCars = (cars: Array<Record<string, unknown>>, filtered = false) => {
      if (!(liveGrid instanceof HTMLElement) || !(message instanceof HTMLElement)) {
        return;
      }

      const orderedCars = newestFirst(cars);
      liveGrid.innerHTML = orderedCars.slice(0, filtered ? 12 : 6).map(renderCarCard).join("");
      liveGrid.hidden = orderedCars.length === 0;

      if (loadingState instanceof HTMLElement) {
        loadingState.hidden = true;
      }

      if (orderedCars.length === 0) {
        message.textContent = filtered
          ? "По этим фильтрам пока нет опубликованных объявлений."
          : "Пока нет опубликованных объявлений.";
        return;
      }

      message.textContent = filtered
        ? `Найдено объявлений: ${orderedCars.length}.`
        : "Показаны самые новые опубликованные объявления.";
    };

    if (searchPanel instanceof HTMLElement && message instanceof HTMLElement) {
      const apiUrl = searchPanel.dataset.apiUrl;
      const placeholderUrl = searchPanel.dataset.placeholderUrl;

      if (apiUrl && apiUrl !== placeholderUrl) {
        fetch(`${apiUrl}/cars`)
          .then((response) => {
            if (!response.ok) {
              throw new Error("latest cars load failed");
            }

            return response.json();
          })
          .then((cars) => {
            if (!Array.isArray(cars) || cars.length === 0) {
              if (loadingState instanceof HTMLElement) {
                loadingState.hidden = true;
              }
              message.textContent = "Пока нет опубликованных объявлений.";
              return;
            }

            allCars = newestFirst(cars);
            applyHeroImage(allCars);
            renderCategories(allCars);
            renderCars(allCars);
          })
          .catch((error) => {
            console.error(error);
            if (loadingState instanceof HTMLElement) {
              loadingState.hidden = true;
            }
            message.textContent = "Не удалось загрузить объявления. Попробуйте обновить страницу.";
          });
      } else {
        if (loadingState instanceof HTMLElement) {
          loadingState.hidden = true;
        }
        message.textContent = "Сервис временно недоступен. Попробуйте позже.";
      }
    }

    searchForm?.addEventListener("submit", (event) => {
      event.preventDefault();

      if (!(searchForm instanceof HTMLFormElement)) {
        return;
      }

      const formData = new FormData(searchForm);
      const filteredCars = allCars.filter((car) => matchesFilters(car, formData));
      renderCars(filteredCars, true);

      if (searchButton instanceof HTMLButtonElement) {
        searchButton.textContent = `Показать: ${filteredCars.length}`;
      }
    });

    resetButton?.addEventListener("click", () => {
      if (searchForm instanceof HTMLFormElement) {
        searchForm.reset();
      }

      if (searchButton instanceof HTMLButtonElement) {
        searchButton.textContent = "Смотреть объявления";
      }

      renderCars(allCars);
    });
  </script>
</BaseLayout>
