---
import BaseLayout from "../../layouts/BaseLayout.astro";

const xanoApiUrl = import.meta.env.PUBLIC_XANO_API_URL;
const placeholderApiUrl = "https://your-xano-api-url.com/api:YOUR_GROUP";
---

<BaseLayout title="Админ-панель авто">
  <section class="section page-hero">
    <div class="container">
      <div class="admin-heading">
        <div>
          <p class="eyebrow">Админ</p>
          <h1>Проверка объявлений</h1>
          <p class="lead">
            Здесь видно, какие машины ждут модерации, какие опубликованы, отклонены,
            заблокированы, удалены или отправлены в архив.
          </p>
        </div>
        <a class="button button-dark" href="/dashboard/new">Добавить объявление</a>
      </div>

      <div
        class="admin-board"
        id="admin-board"
        data-api-url={xanoApiUrl}
        data-placeholder-url={placeholderApiUrl}
        hidden
      >
        <div class="admin-toolbar">
          <label>
            Поиск
            <input id="admin-search" type="search" placeholder="Марка, модель, город, ID" />
          </label>
          <label>
            Статус
            <select id="admin-status">
              <option value="all">Все объявления</option>
              <option value="pending_review">На модерации</option>
              <option value="approved">Опубликованные</option>
              <option value="draft">Черновики</option>
              <option value="rejected">Отклонённые</option>
              <option value="archived">Архив</option>
              <option value="blocked">Заблокированные</option>
              <option value="deleted">Удалённые</option>
              <option value="sold">Проданные</option>
            </select>
          </label>
          <button class="button button-light" id="admin-refresh" type="button">Обновить</button>
        </div>

        <div class="admin-stats" id="admin-stats" aria-label="Сводка по объявлениям"></div>

        <div class="admin-list" id="admin-list">
          <div class="empty-state">
            Загружаю объявления из Xano...
          </div>
        </div>

        <p class="form-message" id="admin-message"></p>
      </div>

      <div class="empty-state" id="admin-access-message">
        Проверяю доступ к модерации...
      </div>
    </div>
  </section>

  <script>
    import { clearAuth, getAuthToken, rememberNext } from "../../lib/authClient";

    type AdminStatus =
      | "all"
      | "draft"
      | "pending_review"
      | "approved"
      | "rejected"
      | "archived"
      | "blocked"
      | "deleted"
      | "sold";

    type AdminCar = {
      id?: number | string;
      slug?: string;
      title?: string;
      brand?: string;
      model?: string;
      year?: number | string;
      mileage?: number | string;
      fuel_type?: string;
      transmission?: string;
      price?: number | string;
      currency?: string;
      city?: string;
      country?: string;
      description?: string;
      status?: AdminStatus;
      main_image_url?: string;
      created_at?: string;
      updated_at?: string;
      user_id?: number | string;
    };

    type AuthMeResponse = {
      user?: {
        id?: number | string;
        email?: string;
        name?: string;
        role?: string;
      };
    };

    const board = document.querySelector("#admin-board");
    const accessMessage = document.querySelector("#admin-access-message");
    const list = document.querySelector("#admin-list");
    const stats = document.querySelector("#admin-stats");
    const message = document.querySelector("#admin-message");
    const search = document.querySelector("#admin-search");
    const status = document.querySelector("#admin-status");
    const refresh = document.querySelector("#admin-refresh");
    const adminToken = getAuthToken();
    const allowedAdminEmails = new Set([
      "ivanovdavid19@gmail.com",
      "ivanovdavid119@gmail.com",
    ]);

    const statusLabels: Record<string, string> = {
      all: "Все",
      draft: "Черновики",
      pending_review: "На модерации",
      approved: "Опубликованные",
      rejected: "Отклонённые",
      archived: "Архив",
      blocked: "Заблокированные",
      deleted: "Удалённые",
      sold: "Проданные",
    };

    const actionLabels: Record<string, string> = {
      approve: "Одобрить",
      reject: "Отклонить",
      archive: "В архив",
      block: "Заблокировать",
      delete: "Удалить",
      restore: "Вернуть",
      sold: "Продано",
    };

    let cars: AdminCar[] = [];

    const redirectToLogin = () => {
      clearAuth();
      rememberNext("/admin/moderation");
      window.location.href = `/login?next=${encodeURIComponent("/admin/moderation")}`;
    };

    const redirectToSupport = () => {
      window.location.href = "/support";
    };

    const setAccessMessage = (value: string) => {
      if (accessMessage instanceof HTMLElement) {
        accessMessage.textContent = value;
      }
    };

    const isAdminUser = (user?: AuthMeResponse["user"]) => {
      const email = String(user?.email || "").trim().toLowerCase();
      const role = String(user?.role || "").trim().toLowerCase();

      return role === "admin" || allowedAdminEmails.has(email);
    };

    const requireAdminAccess = async () => {
      if (!(board instanceof HTMLElement)) {
        return false;
      }

      const apiUrl = board.dataset.apiUrl;
      const placeholderUrl = board.dataset.placeholderUrl;

      if (!apiUrl || apiUrl === placeholderUrl) {
        setAccessMessage("Xano API URL не настроен.");
        return false;
      }

      if (!adminToken) {
        redirectToLogin();
        return false;
      }

      try {
        const response = await fetch(`${apiUrl}/auth/me`, {
          headers: {
            Authorization: `Bearer ${adminToken}`,
          },
        });

        if (response.status === 401 || response.status === 403) {
          redirectToLogin();
          return false;
        }

        if (!response.ok) {
          throw new Error(`Xano auth/me вернул ${response.status}`);
        }

        const payload = (await response.json()) as AuthMeResponse;

        if (!isAdminUser(payload.user)) {
          redirectToSupport();
          return false;
        }

        board.hidden = false;
        if (accessMessage instanceof HTMLElement) {
          accessMessage.hidden = true;
        }
        return true;
      } catch (error) {
        console.error(error);
        setAccessMessage("Не удалось проверить доступ к админ-панели. Попробуйте войти ещё раз.");
        return false;
      }
    };

    const escapeHtml = (value: unknown) =>
      String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");

    const formatPrice = (car: AdminCar) => {
      const price = Number(car.price ?? 0);
      const currency = String(car.currency || "EUR");

      if (!Number.isFinite(price) || price <= 0) {
        return "Цена не указана";
      }

      return new Intl.NumberFormat("ru-RU", {
        style: "currency",
        currency,
        maximumFractionDigits: 0,
      }).format(price);
    };

    const formatDate = (value: unknown) => {
      if (!value) {
        return "Дата не указана";
      }

      const date = new Date(String(value));

      if (Number.isNaN(date.getTime())) {
        return String(value);
      }

      return new Intl.DateTimeFormat("ru-RU", {
        dateStyle: "medium",
        timeStyle: "short",
      }).format(date);
    };

    const normalizeCars = (payload: unknown): AdminCar[] => {
      if (Array.isArray(payload)) {
        return payload;
      }

      if (payload && typeof payload === "object") {
        const record = payload as Record<string, unknown>;
        const possibleList = record.items ?? record.cars ?? record.data ?? record.listings;

        if (Array.isArray(possibleList)) {
          return possibleList;
        }
      }

      return [];
    };

    const getFilteredCars = () => {
      const selectedStatus =
        status instanceof HTMLSelectElement ? status.value : "all";
      const query =
        search instanceof HTMLInputElement ? search.value.trim().toLowerCase() : "";

      return cars.filter((car) => {
        const carStatus = car.status || "draft";
        const statusMatches = selectedStatus === "all" || carStatus === selectedStatus;
        const haystack = [
          car.id,
          car.title,
          car.brand,
          car.model,
          car.city,
          car.country,
          car.status,
          car.year,
        ]
          .filter(Boolean)
          .join(" ")
          .toLowerCase();

        return statusMatches && (!query || haystack.includes(query));
      });
    };

    const renderStats = () => {
      if (!(stats instanceof HTMLElement)) {
        return;
      }

      const statuses = [
        "pending_review",
        "approved",
        "draft",
        "rejected",
        "archived",
        "blocked",
        "deleted",
        "sold",
      ];

      stats.innerHTML = [
        `<button class="stat-card" type="button" data-status="all"><span>${cars.length}</span><strong>Всего</strong></button>`,
        ...statuses.map((item) => {
          const count = cars.filter((car) => (car.status || "draft") === item).length;
          return `<button class="stat-card" type="button" data-status="${item}"><span>${count}</span><strong>${escapeHtml(statusLabels[item])}</strong></button>`;
        }),
      ].join("");
    };

    const getActions = (car: AdminCar) => {
      const current = car.status || "draft";

      if (current === "pending_review") {
        return ["approve", "reject", "block"];
      }

      if (current === "approved") {
        return ["archive", "block", "sold"];
      }

      if (current === "rejected" || current === "archived" || current === "blocked") {
        return ["restore", "delete"];
      }

      if (current === "deleted") {
        return ["restore"];
      }

      return ["approve", "reject"];
    };

    const renderList = () => {
      if (!(list instanceof HTMLElement)) {
        return;
      }

      const filtered = getFilteredCars();

      renderStats();

      if (filtered.length === 0) {
        list.innerHTML = `
          <div class="empty-state">
            Нет объявлений для выбранного фильтра.
          </div>
        `;
        return;
      }

      list.innerHTML = filtered
        .map((car) => {
          const title = car.title || [car.brand, car.model, car.year].filter(Boolean).join(" ");
          const image = car.main_image_url || "/favicon.svg";
          const carStatus = car.status || "draft";
          const actions = getActions(car);

          return `
            <article class="admin-car">
              <img class="admin-car-image" src="${escapeHtml(image)}" alt="${escapeHtml(title || "Авто")}" loading="lazy" />
              <div class="admin-car-main">
                <div class="admin-car-title">
                  <div>
                    <span class="admin-id">ID ${escapeHtml(car.id)}</span>
                    <h2>${escapeHtml(title || "Без названия")}</h2>
                  </div>
                  <span class="status-badge status-${escapeHtml(carStatus)}">${escapeHtml(statusLabels[carStatus] || carStatus)}</span>
                </div>
                <dl class="admin-car-meta">
                  <div><dt>Цена</dt><dd>${escapeHtml(formatPrice(car))}</dd></div>
                  <div><dt>Город</dt><dd>${escapeHtml(car.city || "Не указан")}</dd></div>
                  <div><dt>Пробег</dt><dd>${escapeHtml(car.mileage ? `${Number(car.mileage).toLocaleString("ru-RU")} км` : "Не указан")}</dd></div>
                  <div><dt>Создано</dt><dd>${escapeHtml(formatDate(car.created_at))}</dd></div>
                </dl>
                <p class="admin-description">${escapeHtml(car.description || "Описание не заполнено.")}</p>
                <div class="admin-actions">
                  ${actions
                    .map(
                      (action) =>
                        `<button class="button ${action === "delete" || action === "block" || action === "reject" ? "button-danger" : "button-light"}" type="button" data-action="${action}" data-id="${escapeHtml(car.id)}">${escapeHtml(actionLabels[action])}</button>`,
                    )
                    .join("")}
                  ${
                    car.slug
                      ? `<a class="button button-light" href="/cars/${escapeHtml(car.slug)}" target="_blank" rel="noreferrer">Открыть</a>`
                      : ""
                  }
                </div>
              </div>
            </article>
          `;
        })
        .join("");
    };

    const loadCars = async () => {
      if (!(board instanceof HTMLElement) || !(message instanceof HTMLElement) || !(list instanceof HTMLElement)) {
        return;
      }

      const apiUrl = board.dataset.apiUrl;
      const placeholderUrl = board.dataset.placeholderUrl;

      if (!apiUrl || apiUrl === placeholderUrl) {
        message.textContent = "Сначала укажи PUBLIC_XANO_API_URL.";
        return;
      }

      message.textContent = "Загружаю объявления...";

      try {
        const response = await fetch(`${apiUrl}/admin/moderation?status=all`, {
          headers: {
            Authorization: `Bearer ${adminToken}`,
          },
        });

        if (!response.ok) {
          throw new Error(`Xano вернул ${response.status}`);
        }

        const payload = await response.json();
        cars = normalizeCars(payload);
        renderList();
        message.textContent = `Загружено объявлений: ${cars.length}.`;
      } catch (error) {
        console.error(error);
        list.innerHTML = `
          <div class="empty-state">
            Не удалось загрузить админ-список. Проверь endpoint <strong>GET /admin/moderation?status=all</strong>.
          </div>
        `;
        message.textContent = error instanceof Error ? error.message : "Ошибка загрузки.";
      }
    };

    const runAction = async (action: string, id: string) => {
      if (!(board instanceof HTMLElement) || !(message instanceof HTMLElement)) {
        return;
      }

      const apiUrl = board.dataset.apiUrl;

      if (!apiUrl) {
        return;
      }

      const endpointAction =
        action === "restore"
          ? "approve"
          : action === "archive" || action === "block" || action === "delete" || action === "sold"
            ? action
            : action;

      try {
        message.textContent = `${actionLabels[action] || "Действие"}...`;

        const response = await fetch(`${apiUrl}/admin/cars/${id}/${endpointAction}`, {
          method: "PATCH",
          headers: {
            Authorization: `Bearer ${adminToken}`,
          },
        });

        if (!response.ok) {
          throw new Error(`Xano endpoint для действия "${actionLabels[action] || action}" пока не отвечает.`);
        }

        await loadCars();
      } catch (error) {
        console.error(error);
        message.textContent =
          error instanceof Error
            ? error.message
            : "Не удалось выполнить действие.";
      }
    };

    search?.addEventListener("input", renderList);
    status?.addEventListener("change", renderList);
    refresh?.addEventListener("click", loadCars);

    stats?.addEventListener("click", (event) => {
      const target = event.target;
      const button = target instanceof HTMLElement ? target.closest("button[data-status]") : null;

      if (button instanceof HTMLButtonElement && status instanceof HTMLSelectElement) {
        status.value = button.dataset.status || "all";
        renderList();
      }
    });

    list?.addEventListener("click", async (event) => {
      const target = event.target;
      const button = target instanceof HTMLElement ? target.closest("button[data-action]") : null;

      if (!(button instanceof HTMLButtonElement)) {
        return;
      }

      const id = button.dataset.id;
      const action = button.dataset.action;

      if (!id || !action) {
        return;
      }

      button.disabled = true;
      await runAction(action, id);
      button.disabled = false;
    });

    requireAdminAccess().then((hasAccess) => {
      if (hasAccess) {
        loadCars();
      }
    });
  </script>
</BaseLayout>
