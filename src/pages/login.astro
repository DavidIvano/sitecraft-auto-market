---
import BaseLayout from "../layouts/BaseLayout.astro";

const xanoApiUrl = import.meta.env.PUBLIC_XANO_API_URL;
const xanoAuthApiUrl = import.meta.env.PUBLIC_XANO_AUTH_API_URL ?? xanoApiUrl;
const placeholderApiUrl = "https://your-xano-api-url.com/api:YOUR_GROUP";
const googleStartPath = import.meta.env.PUBLIC_XANO_GOOGLE_AUTH_START_PATH ?? "/oauth/google/init";
---

<BaseLayout title="Вход">
  <section class="section page-hero">
    <div class="container narrow">
      <p class="eyebrow">Авторизация</p>
      <h1>Войти в кабинет</h1>
      <p class="lead">
        Войдите через Google или по email и паролю. Оба способа открывают один и тот же личный кабинет.
      </p>

      <div class="auth-panel" data-api-url={xanoApiUrl} data-placeholder-url={placeholderApiUrl}>
        <form class="form-panel" id="password-login-form">
          <label class="full-field">
            <span>Email</span>
            <input type="email" name="email" autocomplete="email" required />
          </label>

          <label class="full-field">
            <span>Пароль</span>
            <input type="password" name="password" autocomplete="current-password" required />
          </label>

          <button class="button button-dark full-width" type="submit">Войти по email</button>
          <p class="form-message">
            Нет аккаунта? <a href="/register">Зарегистрироваться</a>
          </p>
          <p class="form-message" id="password-login-message">Введите email и пароль.</p>
        </form>

        <div class="auth-divider"><span>или</span></div>

        <button
          class="button button-light full-width"
          id="google-login"
          type="button"
          data-api-url={xanoApiUrl}
          data-auth-api-url={xanoAuthApiUrl}
          data-placeholder-url={placeholderApiUrl}
          data-start-path={googleStartPath}
        >
          Продолжить с Google
        </button>
        <p class="form-message" id="login-message">
          Если у тебя уже есть Google OAuth для SiteCraft Agency, добавь redirect URL автомаркета в тот же Google OAuth Client.
        </p>
      </div>
    </div>
  </section>

  <script>
    import {
      AUTH_DEBUG_KEY,
      consumeNext,
      rememberNext,
      setAuthToken,
      setAuthUser,
    } from "../lib/authClient";

    const button = document.querySelector("#google-login");
    const message = document.querySelector("#login-message");
    const passwordForm = document.querySelector("#password-login-form");
    const passwordMessage = document.querySelector("#password-login-message");

    const getToken = (payload: unknown) => {
      if (!payload || typeof payload !== "object") {
        return null;
      }

      const record = payload as Record<string, unknown>;
      const token = record.authToken ?? record.auth_token ?? record.token ?? record.jwt;

      return typeof token === "string" ? token : null;
    };

    const getUser = (payload: unknown) => {
      if (!payload || typeof payload !== "object") {
        return null;
      }

      const record = payload as Record<string, unknown>;
      return record.user ?? record.me ?? record.authUser ?? null;
    };

    const getAuthUrl = (payload: unknown) => {
      if (typeof payload === "string") {
        return payload;
      }

      if (payload && typeof payload === "object") {
        const record = payload as Record<string, unknown>;
        const value = record.authUrl ?? record.auth_url ?? record.url ?? record.redirect_url;

        if (typeof value === "string") {
          return value;
        }
      }

      return null;
    };

    button?.addEventListener("click", async () => {
      if (!(button instanceof HTMLButtonElement) || !(message instanceof HTMLElement)) {
        return;
      }

      const apiUrl = button.dataset.apiUrl;
      const authApiUrl = button.dataset.authApiUrl || apiUrl;
      const placeholderUrl = button.dataset.placeholderUrl;
      const startPath = button.dataset.startPath || "/oauth/google/init";

      if (!authApiUrl || authApiUrl === placeholderUrl) {
        message.textContent = "Сначала укажи PUBLIC_XANO_API_URL.";
        return;
      }

      const redirectUri = `${window.location.origin}/auth/google/callback`;
      const authStartUrl = new URL(`${authApiUrl}${startPath}`);
      authStartUrl.searchParams.set("redirect_uri", redirectUri);
      const currentParams = new URLSearchParams(window.location.search);
      const debugMode = currentParams.get("debug") === "1";

      message.textContent = "Открываю Google...";
      button.disabled = true;

      try {
        const response = await fetch(authStartUrl.toString());

        if (!response.ok) {
          throw new Error("Xano Google auth start endpoint failed");
        }

        const contentType = response.headers.get("content-type") || "";
        const payload = contentType.includes("application/json")
          ? await response.json()
          : await response.text();
        const authUrl = getAuthUrl(payload);

        if (!authUrl) {
          throw new Error("Xano did not return a Google auth URL");
        }

        const next = currentParams.get("next");

        if (next) {
          rememberNext(next);
        }

        if (debugMode) {
          window.localStorage.setItem(AUTH_DEBUG_KEY, "1");
        }

        window.location.href = authUrl;
      } catch (error) {
        console.error(error);
        button.disabled = false;
        message.textContent = "Не удалось начать вход через Google. Проверь Xano endpoint для OAuth.";
      }
    });

    passwordForm?.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!(passwordForm instanceof HTMLFormElement) || !(passwordMessage instanceof HTMLElement)) {
        return;
      }

      const panel = passwordForm.closest(".auth-panel");
      const apiUrl = panel instanceof HTMLElement ? panel.dataset.apiUrl : "";
      const placeholderUrl = panel instanceof HTMLElement ? panel.dataset.placeholderUrl : "";

      if (!apiUrl || apiUrl === placeholderUrl) {
        passwordMessage.textContent = "Сначала укажи PUBLIC_XANO_API_URL.";
        return;
      }

      const formData = new FormData(passwordForm);
      const payload = {
        email: String(formData.get("email") || "").trim().toLowerCase(),
        password: String(formData.get("password") || ""),
      };

      try {
        passwordMessage.textContent = "Проверяю пароль...";

        const response = await fetch(`${apiUrl}/auth/login`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(payload),
        });
        const contentType = response.headers.get("content-type") || "";
        const result = contentType.includes("application/json")
          ? await response.json()
          : await response.text();

        if (!response.ok) {
          const details =
            result && typeof result === "object"
              ? ((result as Record<string, unknown>).message ?? (result as Record<string, unknown>).code)
              : result;

          throw new Error(typeof details === "string" && details ? details : "Неверный email или пароль.");
        }

        const token = getToken(result);
        const user = getUser(result);

        if (!token) {
          throw new Error("Xano не вернул authToken.");
        }

        setAuthToken(token);

        if (user) {
          setAuthUser(user);
        }

        const next = new URLSearchParams(window.location.search).get("next") || consumeNext("/dashboard");
        passwordMessage.textContent = "Вход выполнен. Открываю кабинет...";
        window.location.href = next;
      } catch (error) {
        passwordMessage.textContent =
          error instanceof Error ? error.message : "Не удалось войти по email.";
      }
    });
  </script>
</BaseLayout>
