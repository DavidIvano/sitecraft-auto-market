---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const xanoApiUrl = import.meta.env.PUBLIC_XANO_API_URL;
const xanoAuthApiUrl = import.meta.env.PUBLIC_XANO_AUTH_API_URL ?? xanoApiUrl;
const placeholderApiUrl = "https://your-xano-api-url.com/api:YOUR_GROUP";
const googleContinuePath = import.meta.env.PUBLIC_XANO_GOOGLE_AUTH_CONTINUE_PATH ?? "/oauth/google/continue";
---

<BaseLayout title="Завершение входа">
  <section class="section page-hero">
    <div class="container narrow">
      <p class="eyebrow">Google OAuth</p>
      <h1>Завершаю вход</h1>
      <div class="empty-state">
        <p id="callback-message" data-api-url={xanoApiUrl} data-auth-api-url={xanoAuthApiUrl} data-placeholder-url={placeholderApiUrl} data-continue-path={googleContinuePath}>
          Получаю токен авторизации от Xano.
        </p>
        <pre class="debug-output" id="callback-debug" hidden></pre>
        <p class="form-message" id="callback-actions" hidden>
          <a href="/auth/check">Проверить вход</a>
          <span> · </span>
          <a href="/dashboard/new">Открыть добавление объявления</a>
        </p>
      </div>
    </div>
  </section>

  <script>
    const message = document.querySelector("#callback-message");
    const debugOutput = document.querySelector("#callback-debug");
    const callbackActions = document.querySelector("#callback-actions");
    const debugLines: string[] = [];

    const showDebug = () => {
      if (debugOutput instanceof HTMLElement) {
        debugOutput.hidden = false;
        debugOutput.textContent = debugLines.join("\n");
      }

      if (callbackActions instanceof HTMLElement) {
        callbackActions.hidden = false;
      }
    };

    const addDebug = (line: string) => {
      debugLines.push(line);
      showDebug();
    };

    const getToken = (payload: unknown) => {
      if (!payload || typeof payload !== "object") {
        return null;
      }

      const record = payload as Record<string, unknown>;
      const token = record.authToken ?? record.auth_token ?? record.token ?? record.jwt;

      return typeof token === "string" ? token : null;
    };

    const getUser = (payload: unknown) => {
      if (!payload || typeof payload !== "object") {
        return null;
      }

      const record = payload as Record<string, unknown>;
      return record.user ?? record.me ?? record.authUser ?? null;
    };

    const finishLogin = async () => {
      if (!(message instanceof HTMLElement)) {
        return;
      }

      const apiUrl = message.dataset.apiUrl;
      const authApiUrl = message.dataset.authApiUrl || apiUrl;
      const placeholderUrl = message.dataset.placeholderUrl;
      const continuePath = message.dataset.continuePath || "/oauth/google/continue";
      const params = new URLSearchParams(window.location.search);
      const code = params.get("code");
      const error = params.get("error");
      const debugMode = window.localStorage.getItem("sitecraft_auto_market_auth_debug") === "1";

      if (debugMode) {
        addDebug("Debug mode: on");
      }

      if (error) {
        message.textContent = `Google вернул ошибку: ${error}`;
        addDebug(`Google error: ${error}`);
        return;
      }

      if (!code) {
        message.textContent = "В callback URL нет параметра code.";
        addDebug("Google code: missing");
        return;
      }

      if (!authApiUrl || authApiUrl === placeholderUrl) {
        message.textContent = "Сначала укажи PUBLIC_XANO_API_URL.";
        addDebug("Xano API URL: missing");
        return;
      }

      const redirectUri = `${window.location.origin}/auth/google/callback`;
      addDebug(`Google code: received (${code.length} chars)`);
      addDebug(`Continue endpoint: ${authApiUrl}${continuePath}`);
      addDebug(`Redirect URI: ${redirectUri}`);

      try {
        const continueUrl = new URL(`${authApiUrl}${continuePath}`);
        continueUrl.searchParams.set("code", code);
        continueUrl.searchParams.set("redirect_uri", redirectUri);

        const response = await fetch(continueUrl.toString());
        const contentType = response.headers.get("content-type") || "";
        const payload = contentType.includes("application/json")
          ? await response.json()
          : await response.text();
        const safePayload =
          typeof payload === "string"
            ? payload
            : JSON.stringify(
                Object.fromEntries(
                  Object.entries(payload).map(([key, value]) => [
                    key,
                    ["authToken", "auth_token", "token", "jwt"].includes(key)
                      ? "[received]"
                      : value,
                  ]),
                ),
                null,
                2,
              );

        addDebug(`Continue status: ${response.status}`);
        addDebug(`Continue response: ${safePayload}`);

        if (!response.ok) {
          const details =
            payload && typeof payload === "object"
              ? ((payload as Record<string, unknown>).message ?? (payload as Record<string, unknown>).code)
              : payload;

          throw new Error(
            typeof details === "string" && details
              ? details
              : "Xano Google auth continue endpoint failed",
          );
        }

        const token = getToken(payload);
        const user =
          getUser(payload) ??
          (payload && typeof payload === "object"
            ? {
                name: (payload as Record<string, unknown>).name,
                email: (payload as Record<string, unknown>).email,
              }
            : null);

        if (!token) {
          throw new Error("Xano did not return auth token");
        }

        window.localStorage.setItem("sitecraft_auto_market_auth_token", token);
        addDebug("Auth token: saved");

        if (user) {
          window.localStorage.setItem("sitecraft_auto_market_user", JSON.stringify(user));
          addDebug("User: saved");
        }

        const authMeResponse = await fetch(`${apiUrl}/auth/me`, {
          headers: {
            Authorization: `Bearer ${token}`,
          },
        });
        const authMeText = await authMeResponse.text();

        addDebug(`Auth check status: ${authMeResponse.status}`);
        addDebug(`Auth check response: ${authMeText}`);

        if (!authMeResponse.ok) {
          window.localStorage.removeItem("sitecraft_auto_market_auth_token");
          window.localStorage.removeItem("sitecraft_auto_market_user");
          throw new Error(`Xano auth/me не принял токен: ${authMeText}`);
        }

        const next = window.localStorage.getItem("sitecraft_auto_market_auth_next") || "/dashboard";
        window.localStorage.removeItem("sitecraft_auto_market_auth_next");
        addDebug(`Next page: ${next}`);

        if (debugMode) {
          window.localStorage.removeItem("sitecraft_auto_market_auth_debug");
          message.textContent = "Вход выполнен. Токен сохранен и проверен.";
          return;
        }

        message.textContent = "Вход выполнен. Перехожу в кабинет...";
        window.location.href = next;
      } catch (error) {
        console.error(error);
        const details = error instanceof Error ? error.message : "Проверь Xano continue endpoint.";
        message.textContent = `Не удалось завершить вход через Google. Xano ответил: ${details}`;
        addDebug(`Final error: ${details}`);
      }
    };

    finishLogin();
  </script>
</BaseLayout>
