---
import BaseLayout from "../layouts/BaseLayout.astro";

const steps = [
  "Создать объявление",
  "Загрузить фото",
  "Отправить на модерацию",
  "Публикация после проверки",
];
---

<BaseLayout title="Продать авто">
  <section class="section page-hero">
    <div class="container narrow">
      <p class="eyebrow">Для продавцов</p>
      <h1>Как продать авто</h1>
      <p class="lead">Добавьте данные автомобиля, загрузите фотографии и отправьте объявление на ручную проверку.</p>
      <a class="button button-dark" href="/dashboard">Перейти в кабинет</a>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="steps-grid">
        {steps.map((step, index) => (
          <div class="step-card">
            <span>{index + 1}</span>
            <strong>{step}</strong>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
