---
const navItems = [
  { href: "/", label: "Главная" },
  { href: "/cars", label: "Авто" },
  { href: "/sell", label: "Продать авто" },
  { href: "/dashboard", label: "Кабинет" },
];

const xanoApiUrl = import.meta.env.PUBLIC_XANO_API_URL;
---

<header class="site-header" data-api-url={xanoApiUrl}>
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="SiteCraft Auto Market">
      <img class="brand-logo" src="/sitecraft-logo.png" alt="" width="44" height="44" decoding="async" />
      <span>SiteCraft Auto Market</span>
    </a>
    <nav class="main-nav" aria-label="Основная навигация">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <div class="header-actions">
      <button class="theme-toggle" type="button" aria-label="Переключить тему" title="Переключить тему">
        <span class="theme-toggle-icon" aria-hidden="true">●</span>
        <span class="theme-toggle-text">Тема</span>
      </button>
      <a class="button button-light auth-link" href="/login">Войти</a>
      <button class="button button-light auth-logout" type="button" hidden>Выйти</button>
      <a class="button button-dark header-action" href="/dashboard/new">Добавить объявление</a>
    </div>
  </div>
  <script>
    import { clearAuth, getAuthToken } from "../lib/authClient";

    const authLink = document.querySelector(".auth-link");
    const authLogout = document.querySelector(".auth-logout");
    const themeToggle = document.querySelector(".theme-toggle");
    const header = document.querySelector(".site-header");
    const token = getAuthToken();
    const apiUrl = header instanceof HTMLElement ? header.dataset.apiUrl : "";

    const updateThemeButton = () => {
      if (!(themeToggle instanceof HTMLButtonElement)) {
        return;
      }

      const theme = document.documentElement.dataset.theme || "light";
      themeToggle.setAttribute("aria-label", theme === "dark" ? "Включить светлую тему" : "Включить тёмную тему");
      const text = themeToggle.querySelector(".theme-toggle-text");
      if (text) {
        text.textContent = theme === "dark" ? "Тёмная" : "Светлая";
      }
    };

    updateThemeButton();

    themeToggle?.addEventListener("click", () => {
      const currentTheme = document.documentElement.dataset.theme || "light";
      const nextTheme = currentTheme === "dark" ? "light" : "dark";
      document.documentElement.dataset.theme = nextTheme;
      localStorage.setItem("sitecraft-theme", nextTheme);
      updateThemeButton();
    });

    const resetHeader = () => {
      clearAuth();
      if (authLink instanceof HTMLAnchorElement) {
        authLink.href = "/login";
        authLink.textContent = "Войти";
      }

      if (authLogout instanceof HTMLButtonElement) {
        authLogout.hidden = true;
      }
    };

    if (token && authLink instanceof HTMLAnchorElement && authLogout instanceof HTMLButtonElement) {
      fetch(`${apiUrl}/auth/me`, {
        headers: { Authorization: `Bearer ${token}` },
      })
        .then((response) => {
          if (!response.ok) {
            resetHeader();
            return;
          }

          authLink.href = "/dashboard";
          authLink.textContent = "Кабинет";
          authLogout.hidden = false;
        })
        .catch(() => {
          resetHeader();
        });
    }

    authLogout?.addEventListener("click", () => {
      clearAuth();
      window.location.href = "/";
    });
  </script>
</header>
