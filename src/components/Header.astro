---
const navItems = [
  { href: "/", label: "Главная" },
  { href: "/cars", label: "Авто" },
  { href: "/sell", label: "Продать авто" },
  { href: "/dashboard", label: "Кабинет" },
];

const xanoApiUrl = import.meta.env.PUBLIC_XANO_API_URL;
---

<header class="site-header" data-api-url={xanoApiUrl}>
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="SiteCraft Auto Market">
      <img class="brand-logo" src="/sitecraft-logo.png" alt="" width="44" height="44" decoding="async" />
      <span>SiteCraft Auto Market</span>
    </a>
    <button
      class="menu-toggle"
      type="button"
      aria-label="Открыть меню"
      aria-controls="site-header-menu"
      aria-expanded="false"
    >
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
    <div class="header-menu" id="site-header-menu">
      <nav class="main-nav" aria-label="Основная навигация">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
      <div class="header-actions">
        <a class="button button-light auth-link" href="/login">Войти</a>
        <button class="button button-light auth-logout" type="button" hidden>Выйти</button>
        <a class="button button-dark header-action" href="/dashboard/new">Добавить объявление</a>
      </div>
    </div>
  </div>
  <script>
    import { clearAuth, getAuthToken } from "../lib/authClient";

    const authLink = document.querySelector(".auth-link");
    const authLogout = document.querySelector(".auth-logout");
    const menu = document.querySelector(".header-menu");
    const menuToggle = document.querySelector(".menu-toggle");
    const header = document.querySelector(".site-header");
    const token = getAuthToken();
    const apiUrl = header instanceof HTMLElement ? header.dataset.apiUrl : "";
    let lastScrollY = window.scrollY;

    const setMenuOpen = (isOpen: boolean) => {
      if (!(menu instanceof HTMLElement) || !(menuToggle instanceof HTMLButtonElement)) {
        return;
      }

      menu.classList.toggle("is-open", isOpen);
      menuToggle.classList.toggle("is-open", isOpen);
      menuToggle.setAttribute("aria-expanded", String(isOpen));
      menuToggle.setAttribute("aria-label", isOpen ? "Закрыть меню" : "Открыть меню");
    };

    menuToggle?.addEventListener("click", () => {
      setMenuOpen(!(menu instanceof HTMLElement && menu.classList.contains("is-open")));
    });

    menu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => setMenuOpen(false));
    });

    const resetHeader = () => {
      clearAuth();
      if (authLink instanceof HTMLAnchorElement) {
        authLink.href = "/login";
        authLink.textContent = "Войти";
      }

      if (authLogout instanceof HTMLButtonElement) {
        authLogout.hidden = true;
      }
    };

    if (token && authLink instanceof HTMLAnchorElement && authLogout instanceof HTMLButtonElement) {
      fetch(`${apiUrl}/auth/me`, {
        headers: { Authorization: `Bearer ${token}` },
      })
        .then((response) => {
          if (!response.ok) {
            resetHeader();
            return;
          }

          authLink.href = "/dashboard";
          authLink.textContent = "Кабинет";
          authLogout.hidden = false;
        })
        .catch(() => {
          resetHeader();
        });
    }

    authLogout?.addEventListener("click", () => {
      clearAuth();
      window.location.href = "/";
    });

    window.addEventListener(
      "scroll",
      () => {
        if (!(header instanceof HTMLElement)) {
          return;
        }

        const currentScrollY = window.scrollY;
        const isMenuOpen = menu instanceof HTMLElement && menu.classList.contains("is-open");
        const isScrollingDown = currentScrollY > lastScrollY;

        header.classList.toggle("is-hidden", isScrollingDown && currentScrollY > 120 && !isMenuOpen);
        lastScrollY = currentScrollY;
      },
      { passive: true },
    );
  </script>
</header>
