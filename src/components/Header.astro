---
const navItems = [
  { href: "/", label: "Главная" },
  { href: "/cars", label: "Авто" },
  { href: "/sell", label: "Продать авто" },
  { href: "/dashboard", label: "Кабинет" },
];

const xanoApiUrl = import.meta.env.PUBLIC_XANO_API_URL;
---

<header class="site-header" data-api-url={xanoApiUrl}>
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="SiteCraft Auto Market">
      <span class="brand-mark">SC</span>
      <span>SiteCraft Auto Market</span>
    </a>
    <nav class="main-nav" aria-label="Основная навигация">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <div class="header-actions">
      <a class="button button-light auth-link" href="/login">Войти</a>
      <button class="button button-light auth-logout" type="button" hidden>Выйти</button>
      <a class="button button-dark header-action" href="/dashboard/new">Добавить объявление</a>
    </div>
  </div>
  <script>
    const authLink = document.querySelector(".auth-link");
    const authLogout = document.querySelector(".auth-logout");
    const header = document.querySelector(".site-header");
    const token = window.localStorage.getItem("sitecraft_auto_market_auth_token");
    const apiUrl = header instanceof HTMLElement ? header.dataset.apiUrl : "";

    const clearAuth = () => {
      window.localStorage.removeItem("sitecraft_auto_market_auth_token");
      window.localStorage.removeItem("sitecraft_auto_market_user");
    };

    if (token && authLink instanceof HTMLAnchorElement && authLogout instanceof HTMLButtonElement) {
      fetch(`${apiUrl}/auth/me`, {
        headers: { Authorization: `Bearer ${token}` },
      })
        .then((response) => {
          if (!response.ok) {
            clearAuth();
            return;
          }

          authLink.href = "/dashboard";
          authLink.textContent = "Кабинет";
          authLogout.hidden = false;
        })
        .catch(() => {
          clearAuth();
        });
    }

    authLogout?.addEventListener("click", () => {
      clearAuth();
      window.location.href = "/";
    });
  </script>
</header>
