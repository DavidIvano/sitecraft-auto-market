PUBLIC_XANO_API_URL=https://your-xano-api-url.com/api:YOUR_GROUP
PUBLIC_XANO_AUTH_API_URL=https://your-xano-api-url.com/api:YOUR_AUTH_GROUP
PUBLIC_SITE_URL=https://your-cloudflare-domain.pages.dev
PUBLIC_XANO_GOOGLE_AUTH_START_PATH=/oauth/google/init
PUBLIC_XANO_GOOGLE_AUTH_CONTINUE_PATH=/oauth/google/continue
